                      <span className="font-bold uppercase mt-1">Kepala Madrasah / Sekolah</span>
                      <div className="h-16" />
                      <span className="font-bold underline">___________________________</span>
                      <span>NIP. _____________________</span>
                    </div>
                    <div className="flex flex-col items-center text-center">
                      <span>Jakarta, ____________ 2026</span>
                      <span className="font-bold uppercase mt-1">Guru Mata Pelajaran</span>
                      <div className="h-16" />
                      <span className="font-bold underline">{generatedRPP.header.namaGuru}</span>
                      <span>NIP. _____________________</span>
                    </div>
                  </div>

                  {/* Print Version Signatures (Takes up less space, aligned beautifully on printed paper) */}
                  <div className="hidden print:block mt-16 grid grid-cols-2 text-xs text-black pt-8 border-t border-black">
                    <div className="flex flex-col items-center text-center">
                      <span>Mengetahui,</span>
                      <span className="font-bold uppercase mt-1">Kepala Madrasah / Sekolah</span>
                      <div className="h-16" />
                      <span className="font-bold underline">___________________________</span>
                      <span>NIP. _____________________</span>
                    </div>
                    <div className="flex flex-col items-center text-center">
                      <span>Jakarta, ____________ 2026</span>
                      <span className="font-bold uppercase mt-1">Guru Mata Pelajaran</span>
                      <div className="h-16" />
                      <span className="font-bold underline">{generatedRPP.header.namaGuru}</span>
                      <span>NIP. _____________________</span>
                    </div>
                  </div>

                </div>

              </motion.div>
              )
            )}

            {/* LKPD LOADING SCREEN */}
            {activeTab === "lkpd" && loadingLKPD && (
              <motion.div
                key="loading-box-lkpd"
                initial={{ opacity: 0, scale: 0.98 }}
                animate={{ opacity: 1, scale: 1 }}
                exit={{ opacity: 0 }}
                className="bg-white rounded-2xl border border-slate-200/80 p-8 shadow-sm flex flex-col items-center justify-center min-h-[450px] text-center"
              >
                <div className="relative mb-6">
                  <div className="w-16 h-16 border-4 border-emerald-100 border-t-emerald-600 rounded-full animate-spin"></div>
                  <div className="absolute inset-0 flex items-center justify-center text-emerald-600">
                    <Heart className="w-6 h-6 animate-pulse text-emerald-600" />
                  </div>
                </div>

                <h3 className="font-sans font-bold text-lg text-slate-800 mb-2">
                  Membuat Lembar Kerja (LKPD) Inspiratif
                </h3>
                <p className="text-slate-500 text-xs max-w-sm leading-relaxed mb-6">
                  Mesin AI sedang memetakan Taksonomi Bloom C1-C6, merancang stimulus kontekstual inovatif, dan merekayasa rubrik penilaian kinerja yang komprehensif.
                </p>

                {/* Staggered progress indicator */}
                <div className="w-full max-w-md bg-slate-100 h-2 rounded-full overflow-hidden mb-3">
                  <div
                    className="bg-gradient-to-r from-emerald-500 to-teal-500 h-full transition-all duration-1000"
                    style={{ width: `${((loadingLKPDStep + 1) / lkpdLoadingSteps.length) * 100}%` }}
                  />
                </div>
                <p className="text-emerald-700 font-mono text-[11px] font-semibold">
                  [Tahap {loadingLKPDStep + 1}/{lkpdLoadingSteps.length}]: {lkpdLoadingSteps[loadingLKPDStep]}
                </p>
              </motion.div>
            )}

            {/* LKPD EMPTY STATE */}
            {activeTab === "lkpd" && !loadingLKPD && !generatedLKPD && (
              <motion.div
                key="empty-box-lkpd"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="bg-gradient-to-br from-indigo-900/5 via-teal-900/5 to-slate-900/5 rounded-2xl border border-slate-200/80 p-8 text-center min-h-[450px] flex flex-col items-center justify-center"
              >
                <CheckSquare className="w-12 h-12 text-slate-400 mb-4" />
                <h3 className="font-sans font-bold text-base text-slate-700">
                  Pratinjau Lembar Kerja Peserta Didik (LKPD - 2 JP)
                </h3>
                <p className="text-slate-500 text-xs max-w-md mt-2 leading-relaxed">
                  Konfigurasikan materi dan Tujuan Pembelajaran di panel kiri, kemudian klik <strong>Formulasikan LKPD Asesmen</strong> untuk memformulasikan stimulus kontekstual dan 8 soal kognitif berjenjang (C1-C6) terperinci.
                </p>
                <div className="mt-6 flex flex-wrap gap-2 justify-center">
                  <div className="flex items-center gap-1.5 text-slate-500 text-[11px] px-3 py-1 bg-white border border-slate-200 rounded-full shadow-inner">
                    <Check className="w-3.5 h-3.5 text-emerald-500" /> Stimulus Kontekstual Remaja
                  </div>
                  <div className="flex items-center gap-1.5 text-slate-500 text-[11px] px-3 py-1 bg-white border border-slate-200 rounded-full shadow-inner">
                    <Check className="w-3.5 h-3.5 text-emerald-500" /> 8 Pertanyaan C1 - C6 Berjenjang
                  </div>
                  <div className="flex items-center gap-1.5 text-slate-500 text-[11px] px-3 py-1 bg-white border border-slate-200 rounded-full shadow-inner">
                    <Check className="w-3.5 h-3.5 text-emerald-500" /> Rubrik Penilaian & Refleksi
                  </div>
                </div>
              </motion.div>
            )}

            {/* LKPD SHEET PRATINJAU */}
            {activeTab === "lkpd" && !loadingLKPD && generatedLKPD && (
              <motion.div
                key="lkpd-sheet"
                initial={{ opacity: 0, y: 15 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0 }}
                className="flex flex-col gap-4"
              >
                {/* Control Action Toolbar */}
                <div className="bg-white border border-slate-200 rounded-xl p-3 shadow-sm flex flex-wrap items-center justify-between gap-3 no-print">
                  <div className="flex items-center gap-2">
                    <button
                      onClick={() => setIsEditingLKPD(!isEditingLKPD)}
                      className={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5 border ${
                        isEditingLKPD
                          ? "bg-slate-800 border-slate-900 text-white"
                          : "bg-white hover:bg-slate-50 border-slate-200 text-slate-700"
                      }`}
                    >
                      <Edit2 className="w-3.5 h-3.5" />
                      {isEditingLKPD ? "Selesai Mengedit" : "Edit LKPD Langsung"}
                    </button>
                    {isEditingLKPD && (
                      <span className="text-[10px] text-amber-700 animate-pulse bg-amber-50 px-2 py-0.5 rounded border border-amber-200">
                        Mode Edit Aktif - Klik & Ketik di kertas dokumen
                      </span>
                    )}
                  </div>

                  <div className="flex items-center gap-1.5">
                    <button
                      onClick={handleCopyLKPDText}
                      className="p-2 hover:bg-slate-50 text-slate-600 hover:text-slate-900 bg-white rounded-lg border border-slate-200 transition-colors"
                      title="Salin LKPD"
                    >
                      <Copy className="w-4 h-4" />
                    </button>
                    <button
                      onClick={handleDownloadLKPDFile}
                      className="p-2 hover:bg-slate-50 text-slate-600 hover:text-slate-900 bg-white rounded-lg border border-slate-200 transition-colors"
                      title="Unduh Teks LKPD"
                    >
                      <Download className="w-4 h-4" />
                    </button>
                    <button
                      onClick={triggerPrint}
                      className="px-3.5 py-2 bg-slate-950 text-white hover:bg-slate-900 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5"
                      title="Cetak Dokumen"
                    >
                      <Printer className="w-4 h-4 text-emerald-400" />
                      Cetak / PDF
                    </button>
                  </div>
                </div>

                {/* Classical Document Sheet (A4 format representation) */}
                <div className="bg-white border border-slate-300 shadow-xl rounded-2xl p-6 sm:p-10 font-serif text-slate-950 relative overflow-hidden print-card">
                  {/* Watermark/Emblem */}
                  <div className="absolute top-0 right-0 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl pointer-events-none"></div>
                  
                  {/* Kop Surat / Header */}
                  <div className="text-center border-b-2 border-slate-900 pb-4 mb-6">
                    <h2 className="text-xs font-sans font-black tracking-widest uppercase text-slate-500">
                      LEMBAR KERJA PESERTA DIDIK (LKPD)
                    </h2>
                    <h3 className="text-lg font-sans font-bold mt-1 text-slate-800">
                      {generatedLKPD.header.namaMadrasah}
                    </h3>
                    <p className="text-[10px] font-sans text-slate-400 tracking-wider">
                      MudarisAI Pendidikan Inovatif Berkarakter • Kurikulum Merdeka • Kelas Mandiri
                    </p>
                  </div>

                  {/* Identitas / Meta */}
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-sans mb-6 bg-slate-50 p-4 rounded-lg border border-slate-100 no-print">
                    <div className="flex flex-col gap-1.5">
                      <div><strong className="text-slate-500">Nama Madrasah:</strong> {isEditingLKPD ? (
                        <input className="border rounded px-1.5 py-0.5 text-xs font-sans bg-white" value={generatedLKPD.header.namaMadrasah} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, namaMadrasah: e.target.value } })} />
                      ) : generatedLKPD.header.namaMadrasah}</div>
                      <div><strong className="text-slate-500">Guru Pengampu:</strong> {isEditingLKPD ? (
                        <input className="border rounded px-1.5 py-0.5 text-xs font-sans bg-white" value={generatedLKPD.header.namaGuru} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, namaGuru: e.target.value } })} />
                      ) : generatedLKPD.header.namaGuru}</div>
                      <div><strong className="text-slate-500">Mata Pelajaran:</strong> {isEditingLKPD ? (
                        <input className="border rounded px-1.5 py-0.5 text-xs font-sans bg-white" value={generatedLKPD.header.mapel} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, mapel: e.target.value } })} />
                      ) : generatedLKPD.header.mapel}</div>
                    </div>
                    <div className="flex flex-col gap-1.5">
                      <div><strong className="text-slate-500">Materi Pokok:</strong> {isEditingLKPD ? (
                        <input className="border rounded px-1.5 py-0.5 text-xs font-sans bg-white" value={generatedLKPD.header.materi} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, materi: e.target.value } })} />
                      ) : generatedLKPD.header.materi}</div>
                      <div><strong className="text-slate-500">Fase/Kelas/Semester:</strong> {isEditingLKPD ? (
                        <input className="border rounded px-1.5 py-0.5 text-xs font-sans bg-white" value={generatedLKPD.header.faseKelasSmt} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, faseKelasSmt: e.target.value } })} />
                      ) : generatedLKPD.header.faseKelasSmt}</div>
                      <div><strong className="text-slate-500">Alokasi Waktu:</strong> {isEditingLKPD ? (
                        <input className="border rounded px-1.5 py-0.5 text-xs font-sans bg-white" value={generatedLKPD.header.alokasiWaktu} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, alokasiWaktu: e.target.value } })} />
                      ) : generatedLKPD.header.alokasiWaktu}</div>
                    </div>
                  </div>

                  {/* Print Meta */}
                  <div className="hidden print:block mb-6 border-b border-slate-300 pb-3">
                    <table className="w-full text-xs font-sans">
                      <tbody>
                        <tr>
                          <td className="py-1 w-1/2"><strong>Nama Madrasah:</strong> {generatedLKPD.header.namaMadrasah}</td>
                          <td className="py-1"><strong>Materi Pokok:</strong> {generatedLKPD.header.materi}</td>
                        </tr>
                        <tr>
                          <td className="py-1"><strong>Penyusun/Guru:</strong> {generatedLKPD.header.namaGuru}</td>
                          <td className="py-1"><strong>Fase/Kelas/Smt:</strong> {generatedLKPD.header.faseKelasSmt}</td>
                        </tr>
                        <tr>
                          <td className="py-1"><strong>Mata Pelajaran:</strong> {generatedLKPD.header.mapel}</td>
                          <td className="py-1"><strong>Alokasi Waktu:</strong> {generatedLKPD.header.alokasiWaktu}</td>
                        </tr>
                      </tbody>
                    </table>
                  </div>

                  {/* Student Entry Fields for physical worksheet printout */}
                  <div className="border border-slate-300 p-3 mb-6 grid grid-cols-2 gap-4 rounded-lg bg-slate-50 text-[11px] font-sans">
                    <div>
                      <strong className="text-slate-400 block text-[9px] uppercase tracking-wider mb-1">Nama Peserta Didik / Kelompok:</strong>
                      <div className="border-b border-dashed border-slate-400 h-6"></div>
                    </div>
                    <div>
                      <strong className="text-slate-400 block text-[9px] uppercase tracking-wider mb-1">Kelas / No. Absen:</strong>
                      <div className="border-b border-dashed border-slate-400 h-6"></div>
                    </div>
                  </div>

                  {/* TP Utama */}
                  <div className="mb-6 page-break-avoid">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      I. TUJUAN PEMBELAJARAN
                    </h4>
                    <div className="mt-2 text-xs leading-relaxed text-slate-800 text-justify font-sans">
                      {isEditingLKPD ? (
                        <textarea rows={2} className="w-full border rounded p-1.5 text-xs font-serif bg-white" value={generatedLKPD.header.tujuanPembelajaran} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, header: { ...generatedLKPD.header, tujuanPembelajaran: e.target.value } })} />
                      ) : generatedLKPD.header.tujuanPembelajaran}
                    </div>
                  </div>

                  {/* Petunjuk Kerja */}
                  <div className="mb-6 page-break-avoid">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      II. PETUNJUK KERJA SISWA
                    </h4>
                    <ol className="list-decimal pl-4 mt-2 text-xs leading-relaxed flex flex-col gap-1.5 text-justify text-slate-800 font-sans">
                      {generatedLKPD.petunjukKerja.map((petunjuk, idx) => (
                        <li key={idx}>
                          {isEditingLKPD ? (
                            <textarea rows={1} className="w-full border rounded p-1 text-xs font-serif bg-white" value={petunjuk} onChange={(e) => {
                              const updated = [...generatedLKPD.petunjukKerja];
                              updated[idx] = e.target.value;
                              setGeneratedLKPD({ ...generatedLKPD, petunjukKerja: updated });
                            }} />
                          ) : petunjuk}
                        </li>
                      ))}
                    </ol>
                  </div>

                  {/* Stimulus Kontekstual */}
                  <div className="mb-6">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      III. STIMULUS LITERASI & DILEMA EKOLOGIS
                    </h4>
                    <div className="mt-2.5 p-4 bg-emerald-50/25 border border-emerald-600/20 rounded-lg text-slate-900">
                      <strong className="block text-xs font-sans text-center mb-2.5 uppercase font-black text-emerald-900">
                        {isEditingLKPD ? (
                          <input className="text-center w-full border rounded text-xs px-1.5" value={generatedLKPD.stimulusKontekstual.judul} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, stimulusKontekstual: { ...generatedLKPD.stimulusKontekstual, judul: e.target.value } })} />
                        ) : generatedLKPD.stimulusKontekstual.judul}
                      </strong>
                      <div className="text-xs text-justify font-serif leading-relaxed whitespace-pre-wrap text-slate-700">
                        {isEditingLKPD ? (
                          <textarea rows={6} className="w-full border rounded p-1.5 text-xs font-serif bg-white" value={generatedLKPD.stimulusKontekstual.narasi} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, stimulusKontekstual: { ...generatedLKPD.stimulusKontekstual, narasi: e.target.value } })} />
                        ) : generatedLKPD.stimulusKontekstual.narasi}
                      </div>
                    </div>
                  </div>

                  {/* Aktivitas Utama */}
                  <div className="mb-6">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      IV. AKTIVITAS PROYEK / BELAJAR ({generatedLKPD.aktivitas.jenis})
                    </h4>
                    <div className="mt-2 text-xs leading-relaxed text-slate-800">
                      <strong className="block mb-1.5 text-slate-900 font-sans text-xs">
                        Tajuk Aktivitas: {isEditingLKPD ? (
                          <input className="border rounded text-xs px-1.5" value={generatedLKPD.aktivitas.namaAktivitas} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, aktivitas: { ...generatedLKPD.aktivitas, namaAktivitas: e.target.value } })} />
                        ) : generatedLKPD.aktivitas.namaAktivitas}
                      </strong>
                      <ul className="list-disc pl-4 mt-2 flex flex-col gap-1.5 text-justify text-slate-700 font-sans">
                        {generatedLKPD.aktivitas.panduanLangkah.map((langkah, idx) => (
                          <li key={idx}>
                            {isEditingLKPD ? (
                              <textarea rows={1} className="w-full border rounded p-1 text-xs font-serif bg-white" value={langkah} onChange={(e) => {
                                const updated = [...generatedLKPD.aktivitas.panduanLangkah];
                                updated[idx] = e.target.value;
                                setGeneratedLKPD({ ...generatedLKPD, aktivitas: { ...generatedLKPD.aktivitas, panduanLangkah: updated } });
                              }} />
                            ) : langkah}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>

                  {/* 8 Pertanyaan Berjenjang */}
                  <div className="mb-6 page-break-before">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      V. EVALUASI DAN PERTANYAAN REKAYASA KOGNITIF BERJENJANG (C1-C6)
                    </h4>
                    <p className="text-[10px] text-slate-500 mt-1 font-sans italic leading-relaxed">
                      Lakukan telaah kritis terhadap stimulus bacaan dan petunjuk aktivitas di atas untuk merumuskan jawaban bernalar berikut:
                    </p>
                    <div className="mt-3 flex flex-col gap-4 text-xs font-sans">
                      {generatedLKPD.pertanyaanC1C6.map((soal, idx) => (
                        <div key={idx} className="border-b border-dashed border-slate-200 pb-4 last:border-none page-break-avoid">
                          <div className="flex items-start gap-1 justify-between mb-1.5 font-bold text-slate-900">
                            <span>Tantangan {idx + 1} • <span className="text-slate-500 text-[10px] font-semibold">{soal.level}</span></span>
                          </div>
                          
                          {/* Socratic Question */}
                          <div className="mb-2 text-slate-800 leading-relaxed font-serif text-justify text-xs">
                            {isEditingLKPD ? (
                              <textarea rows={2} className="w-full border rounded p-1.5 text-xs font-serif bg-white" value={soal.pertanyaan} onChange={(e) => {
                                const updated = [...generatedLKPD.pertanyaanC1C6];
                                updated[idx].pertanyaan = e.target.value;
                                setGeneratedLKPD({ ...generatedLKPD, pertanyaanC1C6: updated });
                              }} />
                            ) : soal.pertanyaan}
                          </div>

                          {/* Scaffolding prompt for student */}
                          <p className="text-[10px] text-emerald-800 bg-emerald-50/60 p-2.5 border border-emerald-100 rounded font-sans leading-relaxed mb-3">
                            <span className="font-bold flex items-center gap-1">💡 Panduan Berpikir Kreatif:</span>
                            {isEditingLKPD ? (
                              <textarea rows={1} className="w-full border rounded p-0.5 text-[10px] bg-white text-slate-700" value={soal.petunjukJawaban} onChange={(e) => {
                                const updated = [...generatedLKPD.pertanyaanC1C6];
                                updated[idx].petunjukJawaban = e.target.value;
                                setGeneratedLKPD({ ...generatedLKPD, pertanyaanC1C6: updated });
                              }} />
                            ) : soal.petunjukJawaban}
                          </p>

                          {/* Answer Box Placeholder for student physical pen write in */}
                          <div className="border border-slate-300 rounded p-2.5 h-20 bg-slate-50/40 relative no-print mb-2">
                            <span className="absolute bottom-2 right-2 text-[9px] font-sans text-slate-300 italic tracking-wide">Guru memberi scaffolding, ketik atau tulis di sini...</span>
                          </div>
                          <div className="hidden print:block border-b border-slate-300 h-16 mb-2"></div>
                        </div>
                      ))}
                    </div>
                  </div>

                  {/* Kesimpulan */}
                  <div className="mb-6 page-break-avoid">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      VI. KESIMPULAN BELAJAR MANDIRI
                    </h4>
                    <div className="mt-2 text-xs leading-relaxed text-justify text-slate-800">
                      {isEditingLKPD ? (
                        <textarea rows={2} className="w-full border rounded p-1.5 text-xs font-serif bg-white" value={generatedLKPD.kesimpulan} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, kesimpulan: e.target.value })} />
                      ) : (
                        <p>{generatedLKPD.kesimpulan}</p>
                      )}
                    </div>
                    {/* Kesimpulan physical entry box */}
                    <div className="border border-slate-300 rounded p-2.5 h-16 bg-slate-50/40 mt-2 relative no-print">
                      <span className="absolute bottom-2 right-2 text-[9px] font-sans text-slate-300 italic tracking-wide">Tarik kesimpulan terdalam di sini...</span>
                    </div>
                    <div className="hidden print:block border-b border-slate-300 h-14 mt-4"></div>
                  </div>

                  {/* Refleksi */}
                  <div className="mb-6">
                    <h4 className="text-xs uppercase font-extrabold tracking-wider font-sans text-slate-800 bg-slate-100 px-2.5 py-1 border-l-4 border-emerald-600">
                      VII. INSTRUMEN REFLEKSI SISWA MADRASAH
                    </h4>
                    <p className="text-[10px] text-slate-500 mt-1 font-sans mb-3 leading-relaxed">
                      {isEditingLKPD ? (
                        <textarea rows={1} className="w-full border rounded p-1 text-xs font-serif bg-white" value={generatedLKPD.refleksi.instruksi} onChange={(e) => setGeneratedLKPD({ ...generatedLKPD, refleksi: { ...generatedLKPD.refleksi, instruksi: e.target.value } })} />
                      ) : generatedLKPD.refleksi.instruksi}
                    </p>
                    <div className="flex flex-col gap-3 font-sans mt-3">
                      {generatedLKPD.refleksi.pertanyaan.map((refPertanyaan, idx) => (
                        <div key={idx} className="border border-slate-100 p-2.5 rounded-lg bg-slate-50/50 page-break-avoid">
                          <p className="text-slate-800 text-xs font-sans font-medium mb-1.5">{idx + 1}. {refPertanyaan}</p>
                          <div className="flex gap-4 mt-2">
