                                {isEditingProtaProsem ? (
                                  <textarea
                                    className="w-full border rounded bg-white p-0.5 text-[11px] font-sans"
                                    rows={2}
                                    value={row.tujuanDanAlurPembelajaran}
                                    onChange={(e) => {
                                      const arr = [...generatedProtaProsem.prota.semesterGenap];
                                      arr[idx].tujuanDanAlurPembelajaran = e.target.value;
                                      setGeneratedProtaProsem({
                                        ...generatedProtaProsem,
                                        prota: { ...generatedProtaProsem.prota, semesterGenap: arr }
                                      });
                                    }}
                                  />
                                ) : (
                                  row.tujuanDanAlurPembelajaran
                                )}
                              </td>
                              <td className="border border-slate-300 p-2 text-center font-semibold text-emerald-800 whitespace-nowrap">
                                {isEditingProtaProsem ? (
                                  <input
                                    className="w-full text-center border rounded bg-white p-0.5 text-[11px]"
                                    value={row.alokasiWaktu}
                                    onChange={(e) => {
                                      const arr = [...generatedProtaProsem.prota.semesterGenap];
                                      arr[idx].alokasiWaktu = e.target.value;
                                      setGeneratedProtaProsem({
                                        ...generatedProtaProsem,
                                        prota: { ...generatedProtaProsem.prota, semesterGenap: arr }
                                      });
                                    }}
                                  />
                                ) : (
                                  row.alokasiWaktu
                                )}
                              </td>
                            </tr>
                          ))}
