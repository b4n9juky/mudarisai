          levelKognitif: assessmentLevel,
          generateDiagnostic: assessmentJenisDiag,
          generateFormative: assessmentJenisForm,
          generateSummative: assessmentJenisSum
        }),
      });

      const data = await response.json();
      clearInterval(timerInterval);

      if (!response.ok) {
        throw new Error(data.error || "Gagal membuat Instrumen Assessment.");
      }

      setGeneratedAssessment(data.assessment);
      if (!assessmentMateri.trim()) {
        setAssessmentMateri(finalMateri);
      }
    } catch (err: any) {
      clearInterval(timerInterval);
      setErrorMsg(err.message || "Terjadi kesalahan saat menghasilkan Instrumen Assessment. Silakan coba kembali.");
    } finally {
      setLoadingAssessment(false);
    }
  };

  const getAssessmentRawText = () => {
    if (!generatedAssessment) return "";
    const g = generatedAssessment;
    let text = `PAKET INSTRUMEN ASESMEN & EVALUASI BELAJAR DIGITAL
==================================================
Mata Pelajaran  : ${g.header.mapel}
Materi Pokok    : ${g.header.materi}
Fase / Kelas    : ${g.header.faseKelasSmt}
Alokasi Waktu   : ${g.header.alokasiWaktu}
Nama Madrasah   : ${g.header.namaMadrasah}
Guru Pengampu   : ${g.header.namaGuru}
Tujuan Belajar  : ${g.header.tujuanPembelajaran}
==================================================\n\n`;

    if (g.asesmenDiagnostik) {
      text += `1. ASESMEN DIAGNOSTIK (AWAL BELAJAR)
--------------------------------------------------
Tujuan Diagnostik Kognitif: ${g.asesmenDiagnostik.kognitif.tujuan}
\nPertanyaan Diagnostik Kognitif:\n`;
      g.asesmenDiagnostik.kognitif.pertanyaan.forEach((q) => {
        text += `- Soal ${q.no}: ${q.soal}\n  Tindak Lanjut Guru: ${q.tindakLanjut}\n`;
      });

      text += `\nTujuan Diagnostik Non-Kognitif: ${g.asesmenDiagnostik.nonKognitif.tujuan}
\nPertanyaan Kondisi Emosional & Gaya Belajar:\n`;
      g.asesmenDiagnostik.nonKognitif.aspek.forEach((a, i) => {
        text += `- Tanya ${i+1}: ${a.pertanyaan}\n  Aspek Diagnostik: ${a.indikator}\n`;
      });
      text += `\n==================================================\n\n`;
    }

    if (g.asesmenFormatif) {
      text += `2. ASESMEN FORMATIF (DALAM PROSES BELAJAR)
--------------------------------------------------
* LEMBAR OBSERVASI SIKAP 
Instruksi: ${g.asesmenFormatif.observasiSikap.instruksi}
Kriteria yang Dinilai: ${g.asesmenFormatif.observasiSikap.kriteria.join(", ")}

Rubrik Pedoman Penilaian Sikap:
`;
      g.asesmenFormatif.observasiSikap.rubrik.forEach((rub, idx) => {
        text += `Kriteria ${idx + 1}:\n- Skor 4 (Sangat Baik): ${rub.skor4}\n- Skor 3 (Baik): ${rub.skor3}\n- Skor 2 (Cukup): ${rub.skor2}\n- Skor 1 (Perlu Bimbingan): ${rub.skor1}\n`;
      });

      text += `\n* LEMBAR REFLEKSI / PENILAIAN DIRI SISWA
Instruksi Siswa: ${g.asesmenFormatif.penilaianDiri.instruksi}
Pernyataan Refleksi Diri:\n`;
      g.asesmenFormatif.penilaianDiri.pernyataan.forEach((str, i) => {
        text += `- Pernyataan ${i + 1}: ${str}\n`;
      });
      text += `\n==================================================\n\n`;
    }

    if (g.asesmenSumatif) {
      text += `3. ASESMEN SUMATIF (EVALUASI AKHIR MATERI)
--------------------------------------------------
Kisi-Kisi Asesmen: ${g.asesmenSumatif.kisiKisi}

BUTIR DAN PILIHAN SOAL SUMATIF:
`;
      g.asesmenSumatif.soalPgDanEsai.forEach((item, idx) => {
        text += `\nSoal ${item.no} [Tipe: ${item.tipe}] [Level: ${item.tingkatKognitif}]
Pertanyaan: ${item.pertanyaan}\n`;
        if (item.opsi) {
          item.opsi.forEach((o) => {
            text += `   ${o}\n`;
          });
        }
        text += `Kunci Jawaban: ${item.kunciJawaban}\nPenjelasan Ilmiah: ${item.penjelasan}\n--------------------------------------------------\n`;
      });

      text += `\nRUBRIK PENILAIAN SUMATIF (ESAI & PROYEK):
`;
      g.asesmenSumatif.rubrikPenilaianSumatif.forEach((rub) => {
        text += `- Kriteria: ${rub.kriteria}\n`;
        rub.deskripsiSkor.forEach((d) => {
          text += `  ${d}\n`;
        });
      });
    }

    return text;
  };

  const [assessmentToast, setAssessmentToast] = useState(false);
  const handleCopyAssessmentText = () => {
    navigator.clipboard.writeText(getAssessmentRawText());
    setAssessmentToast(true);
    setTimeout(() => {
      setAssessmentToast(false);
    }, 3000);
  };

  const handleDownloadAssessmentFile = () => {
    const element = document.createElement("a");
    const file = new Blob([getAssessmentRawText()], { type: "text/plain;charset=utf-8" });
    element.href = URL.createObjectURL(file);
    const fileName = `Asesmen_${mapel.replace(/[^a-zA-Z0-9]/g, "_")}_${(assessmentMateri || materi).replace(/[^a-zA-Z0-9]/g, "_")}.txt`;
    element.download = fileName;
    document.body.appendChild(element);
    element.click();
    document.body.removeChild(element);
  };

  const hasGeneratedContent = 
    activeTab === "rpp" 
      ? !!generatedRPP 
      : activeTab === "lkpd" 
        ? !!generatedLKPD 
        : activeTab === "prota_prosem"
          ? !!generatedProtaProsem
          : !!generatedAssessment;

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans antialiased flex flex-col">
      {/* Visual Header / Navigation Bar following "Clean Minimalism" theme */}
      <header className="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 flex-shrink-0 no-print">
        <div className="flex items-center gap-3">
          <div className="w-8 h-8 bg-emerald-600 rounded flex items-center justify-center text-white flex-shrink-0">
            <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h1 className="text-xl font-bold tracking-tight text-slate-800">
            Mudaris<span className="text-emerald-600">AI</span>
          </h1>
          <span className="px-2 py-0.5 bg-slate-100 text-slate-500 text-[10px] uppercase font-bold tracking-wider rounded border border-slate-200/50">
            Multitool RPP, LKPD & PROSEM v2.3
          </span>
        </div>
        <div className="flex items-center gap-4">
          <div className="text-right hidden sm:block">
            <p className="text-xs font-semibold text-slate-700">{namaGuru || "Guru Profesional"}</p>
            <p className="text-[10px] text-slate-400 italic">Mata Pelajaran: {mapel || "-"}</p>
          </div>
          {activeTab === "rpp" && generatedRPP && (
            <button
              onClick={() => {
                setGeneratedRPP(null);
                setIsEditing(false);
              }}
              className="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-700 bg-white rounded-md text-xs font-semibold transition-all flex items-center gap-1.5"
            >
              <RefreshCw className="w-3.5 h-3.5" />
              Buat RPP Baru
            </button>
          )}
          {activeTab === "lkpd" && generatedLKPD && (
            <button
              onClick={() => {
                setGeneratedLKPD(null);
                setIsEditingLKPD(false);
              }}
              className="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-700 bg-white rounded-md text-xs font-semibold transition-all flex items-center gap-1.5"
            >
              <RefreshCw className="w-3.5 h-3.5" />
              Buat LKPD Baru
            </button>
          )}
          {activeTab === "prota_prosem" && generatedProtaProsem && (
            <button
              onClick={() => {
                setGeneratedProtaProsem(null);
                setIsEditingProtaProsem(false);
              }}
              className="px-4 py-2 border border-slate-200 hover:bg-slate-50 text-slate-700 bg-white rounded-md text-xs font-semibold transition-all flex items-center gap-1.5"
            >
              <RefreshCw className="w-3.5 h-3.5" />
              Buat PROTA/PROSEM Baru
            </button>
          )}
          <button
            onClick={() => setShowExplanation(!showExplanation)}
            className="p-2 bg-white hover:bg-slate-50 text-slate-500 hover:text-slate-700 rounded-md transition-colors border border-slate-200 animate-none"
            title="Klik untuk melihat info kurikulum"
          >
            <HelpCircle className="w-4.5 h-4.5" />
          </button>
        </div>
      </header>

      {/* Sub-header navigation tabs for RPP vs LKPD vs PROTA & PROSEM */}
      <div className="bg-slate-100 border-b border-slate-200 py-2 px-8 flex items-center gap-2 overflow-x-auto no-print">
        <button
          onClick={() => {
            setActiveTab("rpp");
            setErrorMsg("");
          }}
          className={`px-4 py-1.5 text-xs font-bold rounded flex items-center gap-2 transition-all ${
            activeTab === "rpp"
              ? "bg-slate-900 text-white shadow-sm"
              : "bg-white border border-slate-200 text-slate-600 hover:text-slate-800 hover:bg-indigo-50/20"
          }`}
        >
          <BookOpen className="w-3.5 h-3.5" />
          Rencana Pelaksanaan Pembelajaran (RPP)
        </button>
        <button
          onClick={() => {
            setActiveTab("lkpd");
            setErrorMsg("");
            // Proactively prefill from standard mapel/materi if lkpdMateri/lkpdTP are blank
            if (!lkpdMateri && materi) {
              setLkpdMateri(materi);
            }
            if (!lkpdTP && generatedRPP && generatedRPP.desainPembelajaran.tujuanPembelajaran.length > 0) {
              setLkpdTP(generatedRPP.desainPembelajaran.tujuanPembelajaran[0]);
            }
          }}
          className={`px-4 py-1.5 text-xs font-bold rounded flex items-center gap-2 transition-all ${
            activeTab === "lkpd"
              ? "bg-slate-900 text-white shadow-sm"
              : "bg-white border border-slate-200 text-slate-600 hover:text-slate-800 hover:bg-indigo-50/20"
          }`}
        >
          <CheckSquare className="w-3.5 h-3.5" />
          Lembar Kerja Peserta Didik (LKPD - 2 JP)
        </button>
        <button
          onClick={() => {
            setActiveTab("prota_prosem");
            setErrorMsg("");
            // Proactively copy available inputs from RPP or default sets
            if (!protaCP) {
              if (materiCPInput) {
                setProtaCP(materiCPInput);
              } else if (generatedRPP) {
                setProtaCP(generatedRPP.desainPembelajaran.capaianPembelajaran);
              } else {
                setProtaCP("Peserta didik mampu memahami dan menganalisis materi pembelajaran secara komprehensif, kritis, serta menerapkan nilai akhlak luhur Panca Cinta.");
              }
            }
            if (!protaTP) {
              if (generatedRPP && generatedRPP.desainPembelajaran.tujuanPembelajaran.length > 0) {
                setProtaTP(generatedRPP.desainPembelajaran.tujuanPembelajaran.map((it, idx) => `${idx + 1}. ${it}`).join("\n"));
              } else if (rppTPInput) {
                setProtaTP(rppTPInput);
              } else if (lkpdTP) {
                setProtaTP(`1. ${lkpdTP}\n2. Menganalisis hikmah aplikatif materi pokok\n3. Merefleksikan implementasi nilai cinta sesama`);
              } else {
                setProtaTP(`1. Memahami konsep utama ${materi || "materi pokok"} secara mendalam\n2. Menganalisis korelasi praktis dalam kehidupan\n3. Merefleksikan wujud Panca Cinta dalam keseharian`);
              }
            }
            if (!protaATP) {
              setProtaATP(
                "Bab 1: Eksplorasi Konseptual (Minggu 1-3)\nBab 2: Analisis Kritis Kontekstual (Minggu 4-6)\nBab 3: Refleksi Pengalaman & Aksi Nyata Panca Cinta (Minggu 7-8)"
              );
            }
          }}
          className={`px-4 py-1.5 text-xs font-bold rounded flex items-center gap-2 transition-all ${
            activeTab === "prota_prosem"
              ? "bg-slate-900 text-white shadow-sm"
              : "bg-white border border-slate-200 text-slate-600 hover:text-slate-800 hover:bg-emerald-50/20"
          }`}
        >
          <Award className="w-3.5 h-3.5" />
          PROTA & PROSEM (Kurikulum Merdeka)
        </button>
        <button
          onClick={() => {
            setActiveTab("instrumen_asesmen");
            setErrorMsg("");
            if (!assessmentTP) {
              if (lkpdTP) {
                setAssessmentTP(lkpdTP);
              } else if (generatedRPP && generatedRPP.desainPembelajaran.tujuanPembelajaran.length > 0) {
                setAssessmentTP(generatedRPP.desainPembelajaran.tujuanPembelajaran[0]);
              } else if (rppTPInput) {
                setAssessmentTP(rppTPInput);
              } else {
                setAssessmentTP(`Menganalisis korelasi praktis materi pokok ${materi || "pembelajaran"} dalam kehidupan sehari-hari.`);
              }
            }
            if (!assessmentMateri) {
              setAssessmentMateri(lkpdMateri || materi);
            }
          }}
          className={`px-4 py-1.5 text-xs font-bold rounded flex items-center gap-2 transition-all ${
            activeTab === "instrumen_asesmen"
              ? "bg-slate-900 text-white shadow-sm"
              : "bg-white border border-slate-200 text-slate-600 hover:text-slate-800 hover:bg-teal-50/20"
          }`}
        >
          <ClipboardList className="w-3.5 h-3.5 text-teal-600" />
          Instrumen Asesmen (Kurikulum Merdeka)
        </button>
      </div>

      {/* Main Container - Responsive layout */}
      <main className="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        {/* TOP LEVEL: Info / Explanation Banner */}
        {showExplanation && (
          <motion.div
            initial={{ opacity: 0, y: -10 }}
            animate={{ opacity: 1, y: 0 }}
            className="col-span-12 bg-white border border-slate-200 rounded-xl p-5 relative overflow-hidden shadow-sm no-print"
          >
            <button
              onClick={() => setShowExplanation(false)}
              className="absolute top-3 right-3 text-slate-500 hover:text-slate-800 font-bold text-xs bg-slate-100 hover:bg-slate-200 px-2 py-1 rounded transition-colors"
            >
              Tutup
            </button>
            <h3 className="text-slate-800 font-display font-bold text-sm mb-2 flex items-center gap-2">
              <Sparkles className="w-4 h-4 text-emerald-600" />
              PENDIDIKAN INTEGRATIF: DEEP LEARNING & PANCA CINTA
            </h3>
            <p className="text-slate-500 text-xs leading-relaxed max-w-5xl">
              Model RPP ini mengawinkan prinsip <strong>Deep Learning (Pembelajaran Mendalam)</strong> yang menekankan proses aktif yang bersifat <strong>Mindful</strong> (Siswa hadir utuh dengan kesadaran penuh), <strong>Meaningful</strong> (Menemukan hikmah & relevansi hidup), dan <strong>Joyful</strong> (Menyenangkan dan bermakna). 
              Pembelajaran ini juga secara eksplisit menyisipkan <strong>Panca Cinta (Kurikulum Cinta)</strong> untuk menumbuhkan karakter mulia: cinta pada Allah & Rasul-Nya, cinta ilmu pengetahuan, cinta diri & sesama, cinta lingkungan hidup ekologi, serta cinta tanah air & bangsa Indonesia.
            </p>
          </motion.div>
        )}

        {/* Dynamic Column Split */}
        <div className={`col-span-12 ${hasGeneratedContent ? "lg:col-span-5" : "lg:col-span-12 max-w-4xl mx-auto w-full"} flex flex-col gap-6 transition-all duration-300 no-print`}>
          
          {activeTab === "rpp" && (
            <>
              {/* Quick Presets & AI Subject Requester panel complying with Clean Minimalism */}
          <div className="bg-white rounded-xl p-5 border border-slate-200 shadow-sm flex flex-col gap-4">
            <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-2 border-b border-slate-100 pb-3">
              <div>
                <h3 className="text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1.5">
                  <Award className="w-4 h-4 text-emerald-600" />
                  MATA PELAJARAN & PRESET CEPAT
                </h3>
                <p className="text-[10px] text-slate-400 mt-0.5">Pilih mata pelajaran yang sudah terkonfigurasi atau request melalui Asisten AI di bawah</p>
              </div>

              {/* Category selector pills */}
              <div className="flex items-center gap-1 bg-slate-100 p-0.5 rounded border border-slate-200/50">
                {[
                  { value: "semua", label: "Semua" },
                  { value: "agama", label: "Agama" },
                  { value: "umum", label: "Umum / Sains" }
                ].map((cat) => (
                  <button
                    key={cat.value}
                    type="button"
                    onClick={() => setSelectedPresetCat(cat.value as any)}
                    className={`px-2 py-1 text-[10px] font-semibold rounded transition-colors ${
                      selectedPresetCat === cat.value
                        ? "bg-white text-slate-800 shadow-sm"
                        : "text-slate-400 hover:text-slate-600"
                    }`}
                  >
                    {cat.label}
                  </button>
                ))}
              </div>
            </div>

            {/* Scrollable list of high-quality presets */}
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 max-h-[220px] overflow-y-auto custom-scrollbar pr-1">
              {PRESETS.filter(p => selectedPresetCat === "semua" || p.kategori === selectedPresetCat).map((preset, idx) => (
                <button
                  key={idx}
                  onClick={() => {
                    handleApplyPreset(preset);
                    setParseSuccessMsg(`Template "${preset.nama}" sukses diterapkan!`);
                  }}
                  className="text-left p-3 rounded-lg border border-slate-200 hover:border-emerald-500 hover:bg-slate-50/50 transition-all cursor-pointer group flex flex-col gap-1 bg-white"
                >
                  <div className="flex items-center justify-between">
                    <span className="font-bold text-slate-800 text-xs group-hover:text-emerald-700 line-clamp-1 transition-colors">
                      {preset.nama}
                    </span>
                    <span className={`text-[8px] uppercase tracking-wider font-bold px-1.5 py-0.2 ml-1 rounded ${
                      preset.kategori === "agama" ? "bg-emerald-50 text-emerald-700 border border-emerald-200/30" : "bg-blue-50 text-blue-700 border border-blue-200/30"
                    }`}>
                      {preset.kategori}
                    </span>
                  </div>
                  <span className="text-[10px] text-slate-400 line-clamp-2 leading-relaxed">
                    {preset.deskripsi}
                  </span>
                </button>
              ))}
            </div>

            {/* AI Custom Subject Requester Input Box */}
            <form
              onSubmit={(e) => {
                e.preventDefault();
                handleParseRequest();
              }}
              className="mt-2 pt-4 border-t border-slate-100 flex flex-col gap-2"
            >
              <div className="flex items-center justify-between">
                <label className="text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1.5">
                  <Sparkles className="w-3.5 h-3.5 text-emerald-600 animate-pulse" />
                  MINTA ASISTEN AI KONSEPTUALKAN DRAFT MAPEL LAIN
                </label>
                {parseSuccessMsg && (
                  <span className="text-[10px] text-emerald-600 font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-200/50 animate-fade-in line-clamp-1 max-w-[200px] md:max-w-xs">
                    {parseSuccessMsg}
                  </span>
                )}
              </div>
              <div className="flex gap-2">
                <input
                  type="text"
                  value={aiPrompt}
                  onChange={(e) => setAiPrompt(e.target.value)}
                  placeholder="Contoh: 'PPKn tentang Norma Adat Istiadat Kelas 7' atau 'Aqidah Akhlak tentang Sifat Sabar'..."
                  className="flex-1 px-3 py-2 text-xs border border-slate-200 rounded focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 focus:outline-none bg-slate-50 bg-white"
                />
                <button
                  type="submit"
                  disabled={loadingParse || !aiPrompt.trim()}
                  className="px-4 py-2 bg-emerald-600 border border-emerald-600 hover:bg-emerald-700 disabled:bg-slate-100 disabled:border-slate-200 disabled:text-slate-400 text-white text-xs font-bold rounded shadow-sm transition-all flex items-center gap-1.5 flex-shrink-0"
                >
                  {loadingParse ? (
                    <>
                      <RefreshCw className="w-3 h-3 animate-spin" />
                      Memproses...
                    </>
                  ) : (
                    "Minta Mapel"
                  )}
                </button>
              </div>
              <p className="text-[9px] text-slate-400 leading-relaxed font-light">
                * Ketik mata pelajaran atau materi spesifik kurikulum merdeka apa saja. AI asisten guru akan memformulasikan seluruh parameter, mendeteksi Capaian Pembelajaran (CP) dan insersi Panca Cinta yang relevan secara otomatis. setelah terisi, klik tombol hijau besar di bagian bawah formulir untuk merilis generator RPP lengkap secara terperinci.
              </p>
            </form>
          </div>

          {/* Form Configurator Card */}
          <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <div className="bg-slate-50/50 border-b border-slate-200 p-5 flex items-center justify-between">
              <div className="flex items-center gap-2">
                <FileText className="w-4 h-4 text-emerald-600" />
                <h2 className="font-sans font-bold text-slate-800 text-sm uppercase tracking-wide">
                  KONFIGURASI PARAMETER RPP
                </h2>
              </div>
              <span className="text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 bg-slate-100 text-slate-500 rounded border border-slate-200/50">
                MERDEKA v2.0
              </span>
            </div>

            <div className="p-5 flex flex-col gap-4 max-h-[650px] overflow-y-auto custom-scrollbar">
              
              {/* Fields Grid */}
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                    Nama Madrasah / Sekolah
                  </label>
                  <input
                    type="text"
                    value={namaMadrasah}
                    onChange={(e) => setNamaMadrasah(e.target.value)}
                    placeholder="Contoh: MA Al-Azhar"
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  />
                </div>
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                    Nama Lengkap Guru
                  </label>
                  <input
                    type="text"
                    value={namaGuru}
                    onChange={(e) => setNamaGuru(e.target.value)}
                    placeholder="Contoh: Indah Lestari, M.Si."
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                    Mata Pelajaran (Mapel) <span className="text-rose-500">*</span>
                  </label>
                  <input
                    type="text"
                    value={mapel}
                    onChange={(e) => setMapel(e.target.value)}
                    placeholder="Contoh: Fisika, Fikih, Bahasa Inggris"
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  />
                </div>
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                    Alokasi Waktu
                  </label>
                  <input
                    type="text"
                    value={alokasiWaktu}
                    onChange={(e) => setAlokasiWaktu(e.target.value)}
                    placeholder="Contoh: 2 x 45 Menit"
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  />
                </div>
              </div>

              <div>
                <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                  Fase / Kelas / Semester
                </label>
                <div className="grid grid-cols-2 sm:grid-cols-4 gap-2">
                  {[
                    "Fase D / Kelas 7 / Ganjil",
                    "Fase D / Kelas 8 / Genap",
                    "Fase E / Kelas 10 / Ganjil",
                    "Fase F / Kelas 11 / Ganjil",
                    "Fase F / Kelas 12 / Genap"
                  ].map((presetFase) => (
                    <button
                      key={presetFase}
                      type="button"
                      onClick={() => setFaseKelasSmt(presetFase)}
                      className={`px-2 py-2 rounded text-[11px] font-medium border text-center transition-all ${
                        faseKelasSmt === presetFase
                          ? "border-emerald-500 bg-emerald-50 text-emerald-800"
                          : "border-slate-200 text-slate-600 bg-white hover:bg-slate-50"
                      }`}
                    >
                      {presetFase.replace(/ \/ Kelas.*/, "")} ({presetFase.includes("Kelas 10") ? "Kl.10" : presetFase.includes("Kelas 11") ? "Kl.11" : presetFase.includes("Kelas 12") ? "Kl.12" : "Kl.7/8"})
                    </button>
                  ))}
                  <input
                    type="text"
                    value={faseKelasSmt}
                    onChange={(e) => setFaseKelasSmt(e.target.value)}
                    placeholder="Ketik Fase Manual..."
                    className="col-span-2 px-3 py-1.5 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 bg-white"
                  />
                </div>
              </div>

              <div>
                <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                  Materi Pokok Pembelajaran <span className="text-rose-500">*</span>
                </label>
                <input
                  type="text"
                  value={materi}
                  onChange={(e) => setMateri(e.target.value)}
                  placeholder="Contoh: Energi Terbarukan, Menulis Cerpen, Larutan Penyangga"
                  className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                />
              </div>

              <div>
                <div className="flex justify-between items-center mb-1">
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                    Kesiapan / Identifikasi Awal Siswa
                  </label>
                  <button
                    type="button"
                    onClick={() => setIdentifikasiSiswa("Sebagian besar siswa menyukai gaya belajar berkelompok. Ada 3 siswa yang membutuhkan pendampingan khusus dalam membaca peta konsep, sedangkan 5 siswa sudah siap dengan analisis lanjutan.")}
                    className="text-[10px] text-emerald-600 hover:underline font-semibold"
                  >
                    Gunakan Contoh Cepat
                  </button>
                </div>
                <textarea
                  value={identifikasiSiswa}
                  onChange={(e) => setIdentifikasiSiswa(e.target.value)}
                  rows={2}
                  className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  placeholder="Isikan identifikasi kesiapan, minat, latar belakang, dan kebutuhan belajar..."
                />
              </div>

              <div>
                <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                  Fokus Capaian Pembelajaran (CP) - (Opsional)
                </label>
                <textarea
                  value={materiCPInput}
                  onChange={(e) => setMateriCPInput(e.target.value)}
                  rows={2}
                  className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  placeholder="Biarkan kosong jika ingin digenerate otomatis berdasarkan materi"
                />
              </div>

              <div>
                <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                  Tujuan Pembelajaran (TP) Acuan - (Opsional)
                </label>
                <textarea
                  value={rppTPInput}
                  onChange={(e) => setRppTPInput(e.target.value)}
                  rows={2}
                  className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                  placeholder="Ketik Tujuan Pembelajaran atau biarkan kosong agar AI memformulasikan secara otomatis..."
                />
              </div>

              {/* Dimensi Profil Lulusan */}
              <div>
                <div className="flex justify-between items-center mb-1.5">
                  <span className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                    Dimensi Profil Lulusan <span className="text-slate-400 font-normal">(Pilih 1-3)</span>
                  </span>
                  <span className="text-[10px] text-slate-400 font-bold">
                    {selectedProfilDimensions.length}/3 Terpilih
                  </span>
                </div>
                <div className="grid grid-cols-2 gap-2">
                  {PROFIL_DIMENSIONS.map((dim) => {
                    const isSelected = selectedProfilDimensions.includes(dim.value);
                    return (
                      <button
                        key={dim.value}
                        type="button"
                        onClick={() => handleToggleDimension(dim.value)}
                        className={`px-3 py-2 rounded text-left text-xs border transition-all flex items-center justify-between ${
                          isSelected
                            ? "border-emerald-500 bg-emerald-50/70 text-emerald-900 font-medium"
                            : "border-slate-200 text-slate-600 bg-white hover:bg-slate-50"
                        }`}
                      >
                        <span className="truncate pr-1">{dim.label}</span>
                        {isSelected ? (
                          <CheckSquare className="w-3.5 h-3.5 text-emerald-600 flex-shrink-0" />
                        ) : (
                          <span className="w-3.5 h-3.5 border border-slate-300 rounded flex-shrink-0" />
                        )}
                      </button>
                    );
                  })}
                </div>
              </div>

              {/* Kurikulum Panca Cinta */}
              <div>
                <div className="flex justify-between items-center mb-1.5">
                  <span className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                    Insersi Kurikulum Panca Cinta <span className="text-slate-400 font-normal">(Pilih 1-3)</span>
                  </span>
                  <span className="text-[10px] text-slate-400 font-bold">
                    {selectedPancaCinta.length}/3 Terpilih
                  </span>
                </div>
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {PANCA_CINTA_OPTIONS.map((cinta) => {
                    const isSelected = selectedPancaCinta.includes(cinta.value);
                    return (
                      <button
                        key={cinta.value}
                        type="button"
                        onClick={() => handleTogglePancaCinta(cinta.value)}
                        className={`px-3 py-2 rounded text-left text-xs border transition-all flex items-center justify-between ${
                          isSelected
                            ? "border-emerald-500 bg-emerald-50/70 text-emerald-900 font-medium"
                            : "border-slate-200 text-slate-600 bg-white hover:bg-slate-50"
                        }`}
                      >
                        <span className="truncate pr-1 flex items-center gap-1">
                          <Heart className="w-3 h-3 text-rose-500 fill-rose-500" />
                          {cinta.label}
                        </span>
                        {isSelected ? (
                          <Check className="w-4 h-4 text-emerald-600 flex-shrink-0" />
                        ) : (
                          <span className="w-3.5 h-3.5 border border-slate-300 rounded flex-shrink-0" />
                        )}
                      </button>
                    );
                  })}
                </div>
              </div>

            </div>

            {/* Error Message */}
            {errorMsg && (
              <div className="mx-5 my-2 p-3 bg-rose-50 border border-rose-200 text-rose-800 rounded text-xs font-medium flex items-center gap-2">
                <span className="w-1.5 h-1.5 bg-rose-600 rounded-full animate-ping flex-shrink-0" />
                <p className="flex-1">{errorMsg}</p>
              </div>
            )}

            {/* Action Bottom Section complying to the exact Clean Minimalism theme button style */}
            <div className="bg-slate-50/50 border-t border-slate-200 p-5">
              <button
                disabled={loading}
                onClick={generateRPP}
                className="w-full py-2.5 bg-emerald-600 hover:bg-emerald-700 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white text-xs font-bold rounded shadow-sm transition-all flex items-center justify-center gap-2"
              >
                {loading ? (
                  <>
                    <RefreshCw className="w-3.5 h-3.5 animate-spin" />
                    MEMBUAT RENCANA PEMBELAJARAN...
                  </>
                ) : (
                  <>
                    <Sparkles className="w-3.5 h-3.5" />
                    PROSES & GENERATOR DETAIL RPP
                  </>
                )}
              </button>
            </div>

          </div>
          </>
          )}

          {/* LKPD PARAMETER CONFIGURATOR */}
          {activeTab === "lkpd" && (
            <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden animate-fade-in flex flex-col gap-0 select-none">
              <div className="bg-slate-50/50 border-b border-slate-200 p-5 flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <CheckSquare className="w-4 h-4 text-emerald-600" />
                  <h2 className="font-sans font-bold text-slate-800 text-sm uppercase tracking-wide">
                    PARAMETER REKAYASA LKPD
                  </h2>
                </div>
                <span className="text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 bg-slate-100 text-slate-500 rounded border border-slate-200/50">
                  MADRASAH ALIYAH
                </span>
              </div>

              <div className="p-5 flex flex-col gap-5 max-h-[600px] overflow-y-auto custom-scrollbar">
                
                {/* 1. Shared Identity Summary Card */}
                <div className="p-3.5 bg-slate-50 rounded-lg border border-slate-200/70 text-xs flex flex-col gap-2">
                  <div className="flex items-center gap-1.5 text-[10px] font-bold text-slate-400 tracking-wider uppercase">
                    Terintegrasi dari Identitas RPP
                  </div>
                  <div className="grid grid-cols-2 gap-x-4 gap-y-1.5 text-slate-600 mt-1">
                    <div><span className="font-medium text-slate-400">Madrasah:</span> {namaMadrasah || "-"}</div>
                    <div><span className="font-medium text-slate-400">Guru:</span> {namaGuru || "-"}</div>
                    <div><span className="font-medium text-slate-400">Mapel:</span> {mapel || "Pilih Mapel di Tab RPP/Isi di bawah"}</div>
                    <div><span className="font-medium text-slate-400">Alokasi Waktu:</span> {alokasiWaktu || "-"}</div>
                    <div className="col-span-2"><span className="font-medium text-slate-400">Fase/Kelas/Smt:</span> {faseKelasSmt || "-"}</div>
                  </div>
                  <p className="text-[10px] text-slate-400 italic mt-1 border-t border-slate-200/60 pt-2">
                    * Parameter global ini diwariskan dari formulir RPP Anda. Anda dapat merujuk materi di bawah ini.
                  </p>
                </div>

                {/* Overrides */}
                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 border-b border-slate-100 pb-4">
                  <div>
                    <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                      Mata Pelajaran (Mapel)
                    </label>
                    <input
                      type="text"
                      value={mapel}
                      onChange={(e) => setMapel(e.target.value)}
                      placeholder="Contoh: Fikih, Fisika"
                      className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                    />
                  </div>
                  <div>
                    <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                      Durasi (Alokasi Waktu)
                    </label>
                    <input
                      type="text"
                      value={alokasiWaktu}
                      onChange={(e) => setAlokasiWaktu(e.target.value)}
                      placeholder="Contoh: 2 x 45 Menit"
                      className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 bg-white"
                    />
                  </div>
                </div>

                {/* 2. Materi Pokok LKPD */}
                <div>
                  <div className="flex justify-between items-center mb-1.5">
                    <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                      Materi Pokok LKPD <span className="text-rose-500">*</span>
                    </label>
                    {materi && (
                      <button
                        type="button"
                        onClick={() => setLkpdMateri(materi)}
                        className="text-[10px] text-emerald-600 hover:underline font-semibold"
                      >
                        Salin dari RPP ({materi})
                      </button>
                    )}
                  </div>
                  <input
                    type="text"
                    value={lkpdMateri}
                    onChange={(e) => setLkpdMateri(e.target.value)}
                    placeholder="Contoh: Konsep Tauhid dan Akhlak Mulia"
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 bg-white"
                  />
                </div>

                {/* 3. Tujuan Pembelajaran LKPD (TP) */}
                <div>
                  <div className="flex justify-between items-center mb-1.5">
                    <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                      Tujuan Pembelajaran (TP) Acuan <span className="text-rose-500">*</span>
                    </label>
                    {generatedRPP && generatedRPP.desainPembelajaran.tujuanPembelajaran.length > 0 && (
                      <button
                        type="button"
                        onClick={() => setLkpdTP(generatedRPP.desainPembelajaran.tujuanPembelajaran[0])}
                        className="text-[10px] text-emerald-600 hover:underline font-semibold"
                      >
                        Salin TP RPP
                      </button>
                    )}
                  </div>
                  <textarea
                    value={lkpdTP}
                    onChange={(e) => setLkpdTP(e.target.value)}
                    rows={3}
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 bg-white"
                    placeholder="Contoh: Peserta didik mampu mengidentifikasi dan merancang strategi mengatasi pencemaran limbah plastik dilingkungan madrasah..."
                  />
                </div>

                {/* 4. Format Aktivitas Belajar */}
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">
                    Format Aktivitas Belajar
                  </label>
                  <div className="grid grid-cols-2 gap-3">
                    {[
                      { value: "Kelompok", label: "Kelompok (Kolaboratif)", desc: "Mendorong gotong royong dan diskusi aktif" },
                      { value: "Individu", label: "Individu (Mandiri)", desc: "Menitikberatkan kemandirian berpikir kritis" }
                    ].map((opt) => (
                      <button
                        key={opt.value}
                        type="button"
                        onClick={() => setLkpdAktivitasJenis(opt.value)}
                        className={`p-3 rounded-lg border text-left flex flex-col gap-1 transition-all ${
                          lkpdAktivitasJenis === opt.value
                            ? "border-emerald-500 bg-emerald-50/40 text-emerald-900 font-semibold"
                            : "border-slate-200 text-slate-600 bg-white hover:bg-slate-50"
                        }`}
                      >
                        <span className="text-xs">{opt.label}</span>
                        <span className="text-[10px] text-slate-400 font-normal leading-tight">{opt.desc}</span>
                      </button>
                    ))}
                  </div>
                </div>

              </div>

              {/* Error Message for LKPD */}
              {errorMsg && (
                <div className="mx-5 my-2 p-3 bg-rose-50 border border-rose-200 text-rose-800 rounded text-xs font-medium flex items-center gap-2">
                  <span className="w-1.5 h-1.5 bg-rose-600 rounded-full animate-ping flex-shrink-0" />
                  <p className="flex-1">{errorMsg}</p>
                </div>
              )}

              {/* Action Bottom Section for LKPD */}
              <div className="bg-slate-50/50 border-t border-slate-200 p-5">
                <button
                  disabled={loadingLKPD}
                  onClick={generateLKPD}
                  className="w-full py-2.5 bg-emerald-600 hover:bg-emerald-700 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white text-xs font-bold rounded shadow-sm transition-all flex items-center justify-center gap-2"
                >
                  {loadingLKPD ? (
                    <>
                      <RefreshCw className="w-3.5 h-3.5 animate-spin" />
                      MEMBUAT DRAF LKPD MADRASAH...
                    </>
                  ) : (
                    <>
                      <Sparkles className="w-3.5 h-3.5" />
                      FORMULASIKAN LKPD ASESMEN (2 JP)
                    </>
                  )}
                </button>
              </div>

            </div>
          )}

          {/* PROTA & PROSEM CONFIGURATOR */}
          {activeTab === "prota_prosem" && (
            <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden animate-fade-in flex flex-col gap-0 select-none">
              <div className="bg-slate-50/50 border-b border-slate-200 p-5 flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <Award className="w-4 h-4 text-emerald-600" />
                  <h2 className="font-sans font-bold text-slate-800 text-sm uppercase tracking-wide">
                    PARAMETER PROTA & PROSEM
                  </h2>
                </div>
                <span className="text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 bg-slate-100 text-slate-500 rounded border border-slate-200/50">
                  MADRASAH ALIYAH
                </span>
              </div>

              <div className="p-5 flex flex-col gap-5 max-h-[600px] overflow-y-auto custom-scrollbar">
                
                {/* 1. Shared Identity Summary Card */}
                <div className="p-3.5 bg-slate-50 rounded-lg border border-slate-200/70 text-xs flex flex-col gap-2">
                  <div className="flex items-center gap-1.5 text-[10px] font-bold text-slate-400 tracking-wider uppercase">
                    Identitas Terintegrasi
                  </div>
                  <div className="grid grid-cols-2 gap-x-4 gap-y-1.5 text-slate-600 mt-1">
                    <div><span className="font-medium text-slate-400">Madrasah:</span> {namaMadrasah || "-"}</div>
                    <div><span className="font-medium text-slate-400">Guru:</span> {namaGuru || "-"}</div>
                    <div><span className="font-medium text-slate-400">Mapel:</span> {mapel || "Isi di Tab RPP"}</div>
                    <div><span className="font-medium text-slate-400">Alokasi Waktu:</span> {alokasiWaktu || "-"}</div>
                    <div className="col-span-2"><span className="font-medium text-slate-400">Fase/Kelas/Smt:</span> {faseKelasSmt || "-"}</div>
                  </div>
                </div>

                {/* 2. Capaian Pembelajaran (CP) */}
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                    1. Capaian Pembelajaran (CP) <span className="text-emerald-600 font-normal">(Acuan Nasional)</span>
                  </label>
                  <textarea
                    value={protaCP}
                    onChange={(e) => setProtaCP(e.target.value)}
                    rows={3}
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 bg-white"
                    placeholder="Masukkan atau tempel draf Capaian Pembelajaran (CP) Madrasah..."
                  />
                </div>

                {/* 3. Tujuan Pembelajaran (TP) */}
                <div>
                  <div className="flex justify-between items-center mb-1.5">
                    <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                      2. Tujuan Pembelajaran (TP) <span className="text-rose-500">*</span>
                    </label>
                    {generatedRPP && generatedRPP.desainPembelajaran.tujuanPembelajaran.length > 0 && (
                      <button
                        type="button"
                        onClick={() => {
                          setProtaTP(generatedRPP.desainPembelajaran.tujuanPembelajaran.map((it, idx) => `${idx + 1}. ${it}`).join("\n"));
                        }}
                        className="text-[10px] text-emerald-600 hover:underline font-semibold"
                      >
                        Salin TP dari RPP
                      </button>
                    )}
                  </div>
                  <textarea
                    value={protaTP}
                    onChange={(e) => setProtaTP(e.target.value)}
                    rows={4}
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 bg-white"
                    placeholder="Tulis butir-butir Tujuan Pembelajaran (TP) - pisahkan dengan baris baru..."
                  />
                </div>

                {/* 4. Alur Tujuan Pembelajaran (ATP) */}
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">
                    3. Alur Tujuan Pembelajaran (ATP) <span className="text-rose-500">*</span>
                  </label>
                  <textarea
                    value={protaATP}
                    onChange={(e) => setProtaATP(e.target.value)}
                    rows={3}
                    className="w-full px-3 py-2 text-xs border border-slate-200 rounded focus:outline-none focus:border-emerald-500 bg-white"
                    placeholder="Format langkah urutan alur tujuan pembelajaran..."
                  />
                </div>

                {/* 5. Kalender Pendidikan Madrasah Upload */}
                <div>
                  <label className="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">
                    4. Kalender Pendidikan Madrasah <span className="text-indigo-600 font-semibold">(File Upload)</span>
                  </label>
                  
                  <div
                    onDragOver={(e) => {
                      e.preventDefault();
                      setCalendarDragOver(true);
                    }}
                    onDragLeave={() => setCalendarDragOver(false)}
                    onDrop={(e) => {
                      e.preventDefault();
                      setCalendarDragOver(false);
                      const files = e.dataTransfer.files;
                      if (files && files.length > 0) {
                        const file = files[0];
                        setUploadedCalendarFile({ name: file.name, size: file.size });
                      }
                    }}
                    onClick={() => {
                      const input = document.createElement("input");
                      input.type = "file";
                      input.accept = ".pdf,.docx,.doc,.xlsx,.xls,.png,.jpg,.jpeg";
                      input.onchange = (e: any) => {
                        const files = e.target.files;
                        if (files && files.length > 0) {
                          const file = files[0];
                          setUploadedCalendarFile({ name: file.name, size: file.size });
                        }
                      };
                      input.click();
                    }}
                    className={`border-2 border-dashed rounded-xl p-6 text-center cursor-pointer transition-all flex flex-col items-center justify-center gap-2 ${
                      calendarDragOver
                        ? "border-emerald-500 bg-emerald-50/50"
                        : uploadedCalendarFile
                          ? "border-emerald-200 bg-emerald-50/10"
                          : "border-slate-200 hover:border-slate-300 bg-slate-50/50 hover:bg-slate-50"
                    }`}
                  >
                    <svg
                      className={`w-8 h-8 ${uploadedCalendarFile ? "text-emerald-500" : "text-slate-400"}`}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        strokeLinecap="round"
                        strokeLinejoin="round"
                        strokeWidth="1.5"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    
                    {uploadedCalendarFile ? (
                      <div className="flex flex-col items-center">
                        <span className="text-xs font-bold text-slate-800 line-clamp-1 max-w-[250px]">
                          {uploadedCalendarFile.name}
                        </span>
                        <span className="text-[10px] text-emerald-600 font-medium mt-0.5">
                          Telah Teunggah ({Math.round(uploadedCalendarFile.size / 1024)} KB)
                        </span>
                      </div>
                    ) : (
                      <div className="flex flex-col items-center">
                        <span className="text-xs font-bold text-slate-700">
                          Tarik & Lepas Kalender Pendidikan di Sini
                        </span>
                        <span className="text-[10px] text-slate-400 mt-1">
                          atau klik untuk memilih file dari komputer Anda (PDF, Excel, Word, Gambar)
                        </span>
                      </div>
                    )}
                  </div>

                  {uploadedCalendarFile && (
                    <div className="flex justify-end mt-1.5">
                      <button
                        type="button"
                        onClick={(e) => {
                          e.stopPropagation();
                          setUploadedCalendarFile(null);
                        }}
                        className="text-[10px] text-red-500 hover:underline font-semibold flex items-center gap-1"
                      >
                        <Trash2 className="w-3 h-3" />
                        Hapus file Kalender
                      </button>
                    </div>
                  )}
                </div>

              </div>

              {/* Error Message */}
              {errorMsg && (
                <div className="mx-5 my-2 p-3 bg-rose-50 border border-rose-200 text-rose-800 rounded text-xs font-medium flex items-center gap-2">
                  <span className="w-1.5 h-1.5 bg-rose-600 rounded-full animate-ping flex-shrink-0" />
                  <p className="flex-1">{errorMsg}</p>
                </div>
              )}

              {/* Action Trigger Button */}
              <div className="bg-slate-50/50 border-t border-slate-200 p-5">
                <button
                  disabled={loadingProtaProsem}
                  onClick={generateProtaProsem}
                  className="w-full py-2.5 bg-emerald-600 hover:bg-emerald-700 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white text-xs font-bold rounded shadow-sm transition-all flex items-center justify-center gap-2"
                >
                  {loadingProtaProsem ? (
                    <>
                      <RefreshCw className="w-3.5 h-3.5 animate-spin" />
                      MEMETAKAN PROTA & PROSEM...
                    </>
                  ) : (
                    <>
                      <Sparkles className="w-3.5 h-3.5" />
                      FORMULASIKAN DOKUMEN PROTA-PROSEM
                    </>
                  )}
                </button>
              </div>
            </div>
          )}

          {/* INSTRUMEN ASESMEN CONFIGURATOR */}
          {activeTab === "instrumen_asesmen" && (
            <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden animate-fade-in flex flex-col gap-0 select-none">
              <div className="bg-slate-50/50 border-b border-slate-200 p-5 flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <ClipboardList className="w-4 h-4 text-teal-600" />
                  <h2 className="font-sans font-bold text-slate-800 text-sm uppercase tracking-wide">
                    PARAMETER ASESMEN
                  </h2>
                </div>
                <span className="text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 bg-teal-100 text-teal-700 rounded border border-teal-200/50">
                  MA KURMER
                </span>
              </div>

              <div className="p-5 flex flex-col gap-5 max-h-[600px] overflow-y-auto custom-scrollbar">
                
                {/* 1. Shared Identity Summary Card */}
                <div className="p-3.5 bg-slate-50 rounded-lg border border-slate-200/70 text-xs flex flex-col gap-2">
                  <div className="flex items-center gap-1.5 text-[10px] font-bold text-slate-400 tracking-wider uppercase">
                    Identitas Terintegrasi
                  </div>
                  <div className="grid grid-cols-2 gap-x-4 gap-y-1.5 text-slate-600 mt-1">
                    <div><span className="font-medium text-slate-400">Madrasah:</span> {namaMadrasah || "-"}</div>
                    <div><span className="font-medium text-slate-400">Guru:</span> {namaGuru || "-"}</div>
                    <div><span className="font-medium text-slate-400">Mapel:</span> {mapel || "Isi di Tab RPP"}</div>
                    <div><span className="font-medium text-slate-400">Alokasi Waktu:</span> {alokasiWaktu || "-"}</div>
                    <div className="col-span-2"><span className="font-medium text-slate-400">Fase/Kelas/Smt:</span> {faseKelasSmt || "-"}</div>
                  </div>
                </div>

                {/* 2. Materi Pokok Field */}
                <div className="flex flex-col gap-2">
                  <label className="text-xs font-bold text-slate-700 flex items-center justify-between">
                    <span>Materi Pokok Asesmen</span>
                    <span className="text-[10px] text-teal-600 font-semibold italic">Acuan Evaluasi</span>
                  </label>
                  <input
                    type="text"
                    value={assessmentMateri}
                    onChange={(e) => setAssessmentMateri(e.target.value)}
                    placeholder="Contoh: Konsep Syukur dan Implementasinya"
                    className="w-full px-3.5 py-2 text-xs bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-teal-500 placeholder:text-slate-400 transition-all font-sans"
                  />
                </div>

                {/* 3. Tujuan Pembelajaran Acuan */}
                <div className="flex flex-col gap-2">
                  <label className="text-xs font-bold text-slate-700 flex items-center justify-between">
                    <span>Tujuan Pembelajaran (TP) yang Diuji</span>
                  </label>
                  <textarea
                    rows={3}
                    value={assessmentTP}
                    onChange={(e) => setAssessmentTP(e.target.value)}
                    placeholder="Sebutkan TP yang melandasi perancangan soal & rubrik..."
                    className="w-full px-3.5 py-2 text-xs bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-teal-500 placeholder:text-slate-400 transition-all font-sans resize-none leading-relaxed"
                  />
                </div>

                {/* 4. Konfigurasi Jenis Asesmen (Checkboxes) */}
                <div className="flex flex-col gap-2.5">
                  <span className="text-xs font-bold text-slate-700">Jenis Asesmen yang Dihasilkan</span>
                  <div className="grid grid-cols-1 gap-2 p-2 bg-slate-50 rounded-lg border border-slate-200/55">
                    <label className="flex items-center gap-2 px-2 py-1.5 cursor-pointer text-xs font-medium text-slate-600 hover:text-slate-800 select-none">
                      <input
                        type="checkbox"
                        checked={assessmentJenisDiag}
                        onChange={(e) => setAssessmentJenisDiag(e.target.checked)}
                        className="rounded border-slate-300 text-teal-600 focus:ring-teal-500"
                      />
                      Asesmen Diagnostik (Awal)
                    </label>
                    <label className="flex items-center gap-2 px-2 py-1.5 cursor-pointer text-xs font-medium text-slate-600 hover:text-slate-800 select-none">
                      <input
                        type="checkbox"
                        checked={assessmentJenisForm}
                        onChange={(e) => setAssessmentJenisForm(e.target.checked)}
                        className="rounded border-slate-300 text-teal-600 focus:ring-teal-500"
                      />
                      Asesmen Formatif (Proses & Sikap P2RA)
                    </label>
                    <label className="flex items-center gap-2 px-2 py-1.5 cursor-pointer text-xs font-medium text-slate-600 hover:text-slate-800 select-none">
                      <input
                        type="checkbox"
                        checked={assessmentJenisSum}
                        onChange={(e) => setAssessmentJenisSum(e.target.checked)}
                        className="rounded border-slate-300 text-teal-600 focus:ring-teal-500"
                      />
                      Asesmen Sumatif (Akhir Bab PG & Esai)
                    </label>
                  </div>
                </div>

                {/* 5. Parameter Sumatif Detail */}
                {assessmentJenisSum && (
                  <div className="p-3.5 bg-teal-50/20 border border-teal-100 rounded-lg flex flex-col gap-4">
                    <div className="text-[10px] uppercase font-bold text-teal-700 tracking-wider">
                      Spesifikasi Soal Sumatif
                    </div>

                    <div className="flex flex-col gap-2">
                      <label className="text-xs font-semibold text-slate-700">Jumlah Soal Pilihan Ganda (PG)</label>
                      <select
                        value={assessmentJumlahSoal}
                        onChange={(e) => setAssessmentJumlahSoal(Number(e.target.value))}
                        className="w-full px-2.5 py-1.5 text-xs bg-white border border-slate-200 rounded-md focus:outline-none focus:ring-1 focus:ring-teal-500"
                      >
                        <option value={5}>5 Butir Soal PG</option>
                        <option value={10}>10 Butir Soal PG</option>
                        <option value={15}>15 Butir Soal PG</option>
                      </select>
                    </div>

                    <div className="flex flex-col gap-2">
                      <label className="text-xs font-semibold text-slate-700">Predominan Level Kognitif</label>
                      <select
                        value={assessmentLevel}
                        onChange={(e) => setAssessmentLevel(e.target.value)}
                        className="w-full px-2.5 py-1.5 text-xs bg-white border border-slate-200 rounded-md focus:outline-none focus:ring-1 focus:ring-teal-500"
                      >
                        <option value="HOTS (Analisis, Evaluasi, Kreasi)">HOTS (Analisis, Evaluasi, Kreasi)</option>
                        <option value="MOTS (Aplikasi, Pemahaman)">MOTS (Aplikasi, Pemahaman)</option>
                        <option value="LOTS (Mengingat dasar)">LOTS (Mengingat dasar)</option>
                      </select>
                    </div>
                  </div>
                )}

              </div>

              {/* Action Trigger Button */}
              <div className="bg-slate-50/50 border-t border-slate-200 p-5">
                <button
                  disabled={loadingAssessment}
                  onClick={generateAssessment}
                  className="w-full py-2.5 bg-teal-600 hover:bg-teal-700 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white text-xs font-bold rounded shadow-sm transition-all flex items-center justify-center gap-2"
                >
                  {loadingAssessment ? (
                    <>
                      <RefreshCw className="w-3.5 h-3.5 animate-spin" />
                      MERUMUSKAN ASESMEN...
                    </>
                  ) : (
                    <>
                      <Sparkles className="w-3.5 h-3.5" />
                      FORMULASIKAN UNIT ASESMEN
                    </>
                  )}
                </button>
              </div>
            </div>
          )}

        </div>

        {/* Dynamic Preview Column */}
        <div className={`col-span-12 ${hasGeneratedContent ? "lg:col-span-7" : "lg:col-span-12"}`}>
          
          <AnimatePresence mode="wait">
            
            {/* 1. Loading Representation with bespoke details */}
            {activeTab === "rpp" && loading && (
              <motion.div
                key="loading-box"
                initial={{ opacity: 0, scale: 0.98 }}
                animate={{ opacity: 1, scale: 1 }}
                exit={{ opacity: 0 }}
                className="bg-white rounded-2xl border border-slate-200/80 p-8 shadow-sm flex flex-col items-center justify-center min-h-[450px] text-center"
              >
                <div className="relative mb-6">
                  <div className="w-16 h-16 border-4 border-emerald-100 border-t-emerald-600 rounded-full animate-spin"></div>
                  <div className="absolute inset-0 flex items-center justify-center text-emerald-600">
                    <Heart className="w-6 h-6 animate-pulse fill-emerald-600 text-emerald-600" />
                  </div>
                </div>

                <h3 className="font-display font-semibold text-lg text-slate-800 mb-2">
                  Membuat Rencana Pembelajaran Berkarakter
                </h3>
                <p className="text-slate-500 text-xs max-w-sm leading-relaxed mb-6">
                  Mesin AI sedang memetakan kurikulum, merancang aktivitas pedagogis inovatif, dan menyelaraskan integrasi cinta di setiap bagian RPP.
                </p>

                {/* Staggered progress indicator */}
                <div className="w-full max-w-md bg-slate-100 h-2 rounded-full overflow-hidden mb-3">
                  <div
                    className="bg-gradient-to-r from-emerald-500 to-teal-500 h-full transition-all duration-1000"
                    style={{ width: `${((loadingStep + 1) / loadingSteps.length) * 100}%` }}
                  />
                </div>
                <p className="text-emerald-700 font-mono text-[11px] font-semibold animate-fade">
                  [Tahap {loadingStep + 1}/{loadingSteps.length}]: {loadingSteps[loadingStep]}
                </p>
              </motion.div>
            )}

            {/* 2. No RPP Generated yet */}
            {activeTab === "rpp" && !loading && !generatedRPP && (
              <motion.div
                key="empty-box"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                className="bg-gradient-to-br from-emerald-900/5 via-teal-900/5 to-slate-900/5 rounded-2xl border border-slate-200/80 p-8 text-center min-h-[450px] flex flex-col items-center justify-center"
              >
                <BookOpen className="w-12 h-12 text-slate-400 mb-4" />
                <h3 className="font-display font-semibold text-base text-slate-700">
                  Pratinjau Rencana Pembelajaran (RPP)
                </h3>
                <p className="text-slate-500 text-xs max-w-md mt-2 leading-relaxed">
                  Silakan isi parameter di sebelah kiri, atau pilih salah satu <strong>Preset Cepat</strong> di atas. Kemudian klik tombol <strong>Buat RPP</strong> untuk mendesain kurikulum inovatif berkarakter secara instan.
                </p>
                <div className="mt-6 flex flex-wrap gap-2 justify-center">
                  <div className="flex items-center gap-1.5 text-slate-500 text-[11px] px-3 py-1 bg-white border border-slate-200 rounded-full shadow-inner">
                    <Check className="w-3.5 h-3.5 text-emerald-500" /> Pendekatan Deep Learning
                  </div>
                  <div className="flex items-center gap-1.5 text-slate-500 text-[11px] px-3 py-1 bg-white border border-slate-200 rounded-full shadow-inner">
                    <Check className="w-3.5 h-3.5 text-emerald-500" /> Insersi Panca Cinta
                  </div>
                  <div className="flex items-center gap-1.5 text-slate-500 text-[11px] px-3 py-1 bg-white border border-slate-200 rounded-full shadow-inner">
                    <Check className="w-3.5 h-3.5 text-emerald-500" /> Rubrik & Refleksi Lengkap
                  </div>
                </div>
              </motion.div>
            )}

            {/* 3. Generated RPP View Sheet (A4 Styling) */}
            {activeTab === "rpp" && !loading && generatedRPP && (
              !generatedRPP?.header ? (
                <div className="p-8 text-center text-rose-600 text-sm bg-white rounded-xl border border-rose-200">
                  Data RPP tidak valid. Silakan klik <strong>"Buat RPP"</strong> lagi.
                </div>
              ) : (
              <motion.div
                key="rpp-sheet"
                initial={{ opacity: 0, y: 15 }}
                animate={{ opacity: 1, y: 0 }}
                className="flex flex-col gap-4"
              >
                {/* Control Action Toolbar */}
                <div className="bg-white border border-slate-200 rounded-xl p-3 shadow-sm flex flex-wrap items-center justify-between gap-3 no-print">
                  <div className="flex items-center gap-2">
                    <button
                      onClick={() => setIsEditing(!isEditing)}
                      className={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5 border ${
                        isEditing
                          ? "bg-slate-800 border-slate-900 text-white"
                          : "bg-white hover:bg-slate-50 border-slate-200 text-slate-700"
                      }`}
                    >
                      <Edit2 className="w-3.5 h-3.5" />
                      {isEditing ? "Selesai Mengedit" : "Edit RPP Langsung"}
                    </button>
                    
                    {isEditing && (
                      <span className="text-[10px] text-amber-700 animate-pulse bg-amber-50 px-2 py-0.5 rounded border border-amber-200">
                        Mode Edit Aktif - Klik & Ketik di kertas dokumen
                      </span>
                    )}
                  </div>

                  <div className="flex items-center gap-1.5">
                    <button
                      onClick={handleCopyText}
                      className="p-2 hover:bg-slate-50 text-slate-600 hover:text-slate-900 rounded-lg border border-slate-200 transition-colors"
                      title="Salin RPP"
                    >
                      <Copy className="w-4 h-4" />
                    </button>
                    <button
                      onClick={handleDownloadFile}
                      className="p-2 hover:bg-slate-50 text-slate-600 hover:text-slate-900 rounded-lg border border-slate-200 transition-colors"
                      title="Ekspor sebagai File Teks"
                    >
                      <Download className="w-4 h-4" />
                    </button>
                    <button
                      onClick={triggerPrint}
                      className="px-4 py-1.5 bg-emerald-600 hover:bg-emerald-700 cursor-pointer text-white rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5 shadow-sm"
                    >
                      <Printer className="w-4 h-4" />
                      Cetak RPP (PDF)
                    </button>
                  </div>
                </div>

                {/* The Absolute Masterpiece: RPP A4 Paper Container */}
                <div id="rpp-printable-area" className="bg-white rounded-2xl border border-slate-300/80 p-8 shadow-md relative overflow-hidden print-card min-h-[297mm] flex flex-col font-serif">
                  
                  {/* Decorative Islamic Style Corner Decors (Double border style) */}
                  <div className="absolute top-0 inset-x-0 h-1.5 bg-emerald-800 no-print" />

                  {/* Header Title Block */}
                  <div className="text-center mb-6">
                    <h2 className="text-lg font-bold tracking-normal uppercase text-black font-serif">
                      RENCANA PELAKSANAAN PEMBELAJARAN (RPP) <br />
                      PANDUAN KURIKULUM DEEP LEARNING BERBASIS PANCA CINTA
                    </h2>
                    <div className="w-48 h-0.5 bg-black mx-auto mt-2 mb-1" />
                    <div className="w-32 h-[1px] bg-black mx-auto" />
                  </div>

                  {/* RPP Table Metadata */}
                  <table className="w-full text-xs text-black border-collapse align-top mb-6">
                    <tbody>
                      <tr>
                        <td className="font-bold py-1 w-1/4">Nama Madrasah / Sekolah</td>
                        <td className="py-1 w-4">:</td>
                        <td className="py-1 w-1/4 font-semibold">
                          {isEditing ? (
                            <input
                              type="text"
                              value={generatedRPP.header.namaMadrasah}
                              onChange={(e) => {
                                const val = e.target.value;
                                setGeneratedRPP(prev => prev ? { ...prev, header: { ...prev.header, namaMadrasah: val } } : null);
                              }}
                              className="font-serif border-b border-black w-full focus:outline-none"
                            />
                          ) : (
                            generatedRPP.header.namaMadrasah
                          )}
                        </td>
                        <td className="font-bold py-1 w-1/4 pl-6">Fase/Kelas/Semester</td>
                        <td className="py-1 w-4">:</td>
                        <td className="py-1 w-1/4 font-semibold">
                          {isEditing ? (
                            <input
                              type="text"
                              value={generatedRPP.header.faseKelasSmt}
                              onChange={(e) => {
                                const val = e.target.value;
                                setGeneratedRPP(prev => prev ? { ...prev, header: { ...prev.header, faseKelasSmt: val } } : null);
                              }}
                              className="font-serif border-b border-black w-full focus:outline-none"
                            />
                          ) : (
                            generatedRPP.header.faseKelasSmt
                          )}
                        </td>
                      </tr>
                      <tr>
                        <td className="font-bold py-1">Nama Guru Pembimbing</td>
                        <td>:</td>
                        <td className="font-semibold">
                          {isEditing ? (
                            <input
                              type="text"
                              value={generatedRPP.header.namaGuru}
                              onChange={(e) => {
                                const val = e.target.value;
                                setGeneratedRPP(prev => prev ? { ...prev, header: { ...prev.header, namaGuru: val } } : null);
                              }}
                              className="font-serif border-b border-black w-full focus:outline-none"
                            />
                          ) : (
                            generatedRPP.header.namaGuru
                          )}
                        </td>
                        <td className="font-bold py-1 pl-6">Alokasi Waktu</td>
                        <td>:</td>
                        <td className="font-semibold">
                          {isEditing ? (
                            <input
                              type="text"
                              value={generatedRPP.header.alokasiWaktu}
                              onChange={(e) => {
                                const val = e.target.value;
                                setGeneratedRPP(prev => prev ? { ...prev, header: { ...prev.header, alokasiWaktu: val } } : null);
                              }}
                              className="font-serif border-b border-black w-full focus:outline-none"
                            />
                          ) : (
                            generatedRPP.header.alokasiWaktu
                          )}
                        </td>
                      </tr>
                      <tr>
                        <td className="font-bold py-1">Mata Pelajaran (Mapel)</td>
                        <td>:</td>
                        <td className="font-semibold">
                          {isEditing ? (
                            <input
                              type="text"
                              value={generatedRPP.header.mapel}
                              onChange={(e) => {
                                const val = e.target.value;
                                setGeneratedRPP(prev => prev ? { ...prev, header: { ...prev.header, mapel: val } } : null);
                              }}
                              className="font-serif border-b border-black w-full focus:outline-none"
                            />
                          ) : (
                            generatedRPP.header.mapel
                          )}
                        </td>
                        <td className="font-bold py-1 pl-6">Materi Pembelajaran</td>
                        <td>:</td>
                        <td className="font-semibold">
                          {isEditing ? (
                            <input
                              type="text"
                              value={generatedRPP.header.materi}
                              onChange={(e) => {
                                const val = e.target.value;
                                setGeneratedRPP(prev => prev ? { ...prev, header: { ...prev.header, materi: val } } : null);
                              }}
                              className="font-serif border-b border-black w-full focus:outline-none"
                            />
                          ) : (
                            generatedRPP.header.materi
                          )}
                        </td>
                      </tr>
                    </tbody>
                  </table>

                  {/* Divider */}
                  <div className="border-t border-black mb-6" />

                  {/* Section A: Identifikasi */}
                  <div className="mb-6 flex flex-col gap-3">
                    <h3 className="font-bold text-xs uppercase bg-slate-100 px-2 py-1 border-l-4 border-emerald-800 text-black">
                      I. TAHAP IDENTIFIKASI PEMBELAJARAN
                    </h3>

                    <div className="pl-4 grid grid-cols-1 gap-3 text-xs text-black leading-relaxed">
                      <div>
                        <strong className="block text-[11px] uppercase tracking-wide">A. Karakteristik & Kesiapan Peserta Didik</strong>
                        {isEditing ? (
                          <textarea
                            value={generatedRPP.identifikasi.pesertaDidikDetail}
                            onChange={(e) => {
                              const val = e.target.value;
                              setGeneratedRPP(prev => prev ? { ...prev, identifikasi: { ...prev.identifikasi, pesertaDidikDetail: val } } : null);
                            }}
                            rows={3}
                            className="font-serif border border-slate-300 w-full p-1 leading-relaxed rounded text-xs focus:outline-none focus:border-black mt-1"
                          />
                        ) : (
                          <p className="mt-0.5 whitespace-pre-wrap">{generatedRPP.identifikasi.pesertaDidikDetail}</p>
                        )}
                      </div>

                      <div className="mt-1">
                        <strong className="block text-[11px] uppercase tracking-wide">B. Relevansi Materi Pelajaran (Sesuai Capaian)</strong>
                        {isEditing ? (
                          <textarea
                            value={generatedRPP.identifikasi.materiPelajaranCP}
                            onChange={(e) => {
                              const val = e.target.value;
                              setGeneratedRPP(prev => prev ? { ...prev, identifikasi: { ...prev.identifikasi, materiPelajaranCP: val } } : null);
                            }}
                            rows={3}
                            className="font-serif border border-slate-300 w-full p-1 leading-relaxed rounded text-xs focus:outline-none focus:border-black mt-1"
                          />
                        ) : (
                          <p className="mt-0.5 whitespace-pre-wrap">{generatedRPP.identifikasi.materiPelajaranCP}</p>
                        )}
                      </div>

                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-1">
                        <div>
                          <strong className="block text-[11px] uppercase tracking-wide">C. Integrasi Dimensi Profil Lulusan</strong>
                          <ul className="list-decimal pl-4 mt-1 flex flex-col gap-1">
                            {generatedRPP.identifikasi.dimensiProfil.map((dim, idx) => (
                              <li key={idx} className="font-semibold text-xs text-black">
                                {dim}
                              </li>
                            ))}
