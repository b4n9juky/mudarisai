          aktivitasJenis: lkpdAktivitasJenis,
        }),
      });

      const data = await response.json();
      clearInterval(timerInterval);

      if (!response.ok) {
        throw new Error(data.error || "Gagal membuat LKPD.");
      }

      setGeneratedLKPD(data.lkpd);
      // Synchronize back if blank
      if (!lkpdMateri.trim()) {
        setLkpdMateri(finalMateri);
      }
    } catch (err: any) {
      clearInterval(timerInterval);
      setErrorMsg(err.message || "Terjadi kesalahan saat menghasilkan LKPD. Silakan coba kembali.");
    } finally {
