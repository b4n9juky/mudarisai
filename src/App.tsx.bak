const PROFIL_DIMENSIONS = [
  { value: "Keimaman dan ketaqwaan terhadap tuhan yang Maha Esa", label: "Keimanan & Ketaqwaan" },
  { value: "Kewargaan", label: "Kewarganegaraan Global" },
  { value: "Penalaran Kritis", label: "Penalaran Kritis" },
  { value: "Kreatifitas", label: "Kreativitas" },
  { value: "Kolaborasi", label: "Kolaborasi" },
  { value: "Kemandirian", label: "Kemandirian" },
  { value: "Kesehatan", label: "Kesehatan Jasmani & Mental" },
  { value: "Komunikasi", label: "Komunikasi Efektif" }
];

const PANCA_CINTA_OPTIONS = [
  { value: "Cinta pada Allah SWT dan Nabi Muhammad SAW", label: "Cinta Allah & Rasul-Nya" },
  { value: "Cinta pada ilmu pengetahuan", label: "Cinta Ilmu Pengetahuan" },
  { value: "Cinta pada lingkungan", label: "Cinta Lingkungan Hidup" },
  { value: "Cinta pada diri dan sesama", label: "Cinta Diri & Sesama Manusia" },
  { value: "Cinta pada tanah air dan bangsa", label: "Cinta Tanah Air & Bangsa" }
];

export default function App() {
  // Input fields state
  const [namaMadrasah, setNamaMadrasah] = useState("MA Al-Khoiriyah");
  const [namaGuru, setNamaGuru] = useState("Indah Lestari, M.Si.");
  const [mapel, setMapel] = useState("");
  const [faseKelasSmt, setFaseKelasSmt] = useState("Fase E / Kelas 10 / Ganjil");
  const [materi, setMateri] = useState("");
  const [alokasiWaktu, setAlokasiWaktu] = useState("2 x 45 Menit");
  const [identifikasiSiswa, setIdentifikasiSiswa] = useState(
    "Siswa memiliki kesiapan awal beragam, sebagian besar menyukai kegiatan kolaborasi aktif. Membutuhkan contoh kontekstual yang dekat dengan kehidupan sehari-hari."
  );
  const [materiCPInput, setMateriCPInput] = useState("");
  const [rppTPInput, setRppTPInput] = useState("");
  const [selectedProfilDimensions, setSelectedProfilDimensions] = useState<string[]>(["Penalaran Kritis", "Kolaborasi"]);
  const [selectedPancaCinta, setSelectedPancaCinta] = useState<string[]>(["Cinta pada ilmu pengetahuan", "Cinta pada diri dan sesama"]);

  // Application flow state
  const [loading, setLoading] = useState(false);
  const [loadingStep, setLoadingStep] = useState(0);
  const [generatedRPP, setGeneratedRPP] = useState<RPPData | null>(null);
  const [errorMsg, setErrorMsg] = useState("");
  
  // Custom interactive state
  const [isEditing, setIsEditing] = useState(false);
  const [showExplanation, setShowExplanation] = useState(true);

  // Active App Mode Tab: "rpp", "lkpd", "prota_prosem", or "instrumen_asesmen"
  const [activeTab, setActiveTab] = useState<"rpp" | "lkpd" | "prota_prosem" | "instrumen_asesmen">("rpp");

  // LKPD dedicated states
  const [lkpdMateri, setLkpdMateri] = useState("");
  const [lkpdTP, setLkpdTP] = useState("");
  const [lkpdAktivitasJenis, setLkpdAktivitasJenis] = useState<"Kelompok" | "Individu" | string>("Kelompok");
  const [loadingLKPD, setLoadingLKPD] = useState(false);
  const [loadingLKPDStep, setLoadingLKPDStep] = useState(0);
  const [generatedLKPD, setGeneratedLKPD] = useState<LKPDData | null>(null);
  const [isEditingLKPD, setIsEditingLKPD] = useState(false);

  // PROTA & PROSEM dedicated states
  const [protaCP, setProtaCP] = useState("");
  const [protaTP, setProtaTP] = useState("");
  const [protaATP, setProtaATP] = useState("");
  const [uploadedCalendarFile, setUploadedCalendarFile] = useState<{ name: string; size: number } | null>(null);
  const [calendarDragOver, setCalendarDragOver] = useState(false);
  const [loadingProtaProsem, setLoadingProtaProsem] = useState(false);
  const [loadingProtaProsemStep, setLoadingProtaProsemStep] = useState(0);
  const [generatedProtaProsem, setGeneratedProtaProsem] = useState<ProtaProsemData | null>(null);
  const [isEditingProtaProsem, setIsEditingProtaProsem] = useState(false);

  // INSTRUMEN ASESMEN dedicated states
  const [assessmentTP, setAssessmentTP] = useState("");
  const [assessmentMateri, setAssessmentMateri] = useState("");
  const [assessmentJumlahSoal, setAssessmentJumlahSoal] = useState<number>(5);
  const [assessmentLevel, setAssessmentLevel] = useState<string>("HOTS (Analisis, Evaluasi, Kreasi)");
  const [assessmentJenisDiag, setAssessmentJenisDiag] = useState(true);
  const [assessmentJenisForm, setAssessmentJenisForm] = useState(true);
  const [assessmentJenisSum, setAssessmentJenisSum] = useState(true);
  const [loadingAssessment, setLoadingAssessment] = useState(false);
  const [loadingAssessmentStep, setLoadingAssessmentStep] = useState(0);
  const [generatedAssessment, setGeneratedAssessment] = useState<AssessmentData | null>(null);
  const [isEditingAssessment, setIsEditingAssessment] = useState(false);

  // Category filter state for presets
  const [selectedPresetCat, setSelectedPresetCat] = useState<"semua" | "agama" | "umum">("semua");

  // AI Assistant custom request states
  const [aiPrompt, setAiPrompt] = useState("");
  const [loadingParse, setLoadingParse] = useState(false);
  const [parseSuccessMsg, setParseSuccessMsg] = useState("");

  const handleParseRequest = async (e?: React.FormEvent) => {
    if (e) e.preventDefault();
    if (!aiPrompt.trim()) return;

    setLoadingParse(true);
    setParseSuccessMsg("");
    setErrorMsg("");

    try {
      const response = await fetch("/api/parse-request", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ prompt: aiPrompt }),
      });

      const data = await response.json();
      if (!response.ok) {
        throw new Error(data.error || "Gagal berkomunikasi dengan asisten AI.");
      }

      // Prefill fields
      if (data.mapel) setMapel(data.mapel);
      if (data.materi) setMateri(data.materi);
      if (data.faseKelasSmt) setFaseKelasSmt(data.faseKelasSmt);
      if (data.identifikasiSiswa) setIdentifikasiSiswa(data.identifikasiSiswa);
      if (data.materiCPInput) setMateriCPInput(data.materiCPInput);
      setRppTPInput("");

      if (Array.isArray(data.selectedProfilDimensions)) {
        // Map elements or keep valid ones
        const validDims = data.selectedProfilDimensions.map((dim: string) => {
          const match = PROFIL_DIMENSIONS.find(p => p.value.toLowerCase() === dim.toLowerCase() || p.label.toLowerCase() === dim.toLowerCase());
          return match ? match.value : null;
        }).filter(Boolean) as string[];
        
        if (validDims.length > 0) {
          setSelectedProfilDimensions(validDims.slice(0, 3));
        }
      }

      if (Array.isArray(data.selectedPancaCinta)) {
        const validLoves = data.selectedPancaCinta.map((love: string) => {
          const match = PANCA_CINTA_OPTIONS.find(p => p.value.toLowerCase() === love.toLowerCase() || p.label.toLowerCase() === love.toLowerCase());
          return match ? match.value : null;
        }).filter(Boolean) as string[];

        if (validLoves.length > 0) {
          setSelectedPancaCinta(validLoves.slice(0, 3));
        }
      }

      setParseSuccessMsg(`Sukses! Formulir RPP berhasil dikonfigurasi untuk "${data.mapel} - ${data.materi}".`);
    } catch (err: any) {
      console.error(err);
      setErrorMsg(err.message || "Gagal memproses permintaan asisten AI.");
    } finally {
      setLoadingParse(false);
    }
  };

  // For loading messages simulation representing high craftsmanship
  const loadingSteps = [
    "Menghubungkan ke Mesin Kurikulum Deep Learning...",
    "Merumuskan Capaian Pembelajaran lintas disiplin...",
    "Menginsersikan integrasi Kurikulum Panca Cinta pada Tujuan Pembelajaran...",
    "Merancang kegiatan pembelajaran bermakna (Mindful, Meaningful, Joyful)...",
    "Menyusun tahapan aktivitas: Memahami, Mengaplikasi, dan Merefleksi...",
    "Menyusun rubrik penilaian komprehensif & instrumen refleksi...",
    "Finishing: Memvalidasi kebenaran struktur RPP dan Kompetensi Global..."
  ];

  const handleApplyPreset = (preset: PresetTemplate) => {
    setNamaMadrasah(preset.namaMadrasah);
    setNamaGuru(preset.namaGuru);
    setMapel(preset.mapel);
    setFaseKelasSmt(preset.faseKelasSmt);
    setMateri(preset.materi);
    setAlokasiWaktu(preset.alokasiWaktu);
    setIdentifikasiSiswa(preset.identifikasiSiswa);
    setMateriCPInput(preset.materiCPInput);
    setRppTPInput("");
    setSelectedProfilDimensions(preset.selectedProfilDimensions);
    setSelectedPancaCinta(preset.selectedPancaCinta);
    setErrorMsg("");
  };

  const handleToggleDimension = (id: string) => {
    if (selectedProfilDimensions.includes(id)) {
      setSelectedProfilDimensions(selectedProfilDimensions.filter(d => d !== id));
    } else {
      if (selectedProfilDimensions.length >= 3) {
        // limit to 3 as requested by the template rules
        return;
      }
      setSelectedProfilDimensions([...selectedProfilDimensions, id]);
    }
  };

  const handleTogglePancaCinta = (id: string) => {
    if (selectedPancaCinta.includes(id)) {
      setSelectedPancaCinta(selectedPancaCinta.filter(c => c !== id));
    } else {
      if (selectedPancaCinta.length >= 3) {
        // limit to 3 as requested by the template rules
        return;
      }
      setSelectedPancaCinta([...selectedPancaCinta, id]);
    }
  };

  const generateRPP = async () => {
    if (!mapel.trim()) {
      setErrorMsg("Mohon masukkan nama Mata Pelajaran (Mapel) terlebih dahulu.");
      return;
    }
    if (!materi.trim()) {
      setErrorMsg("Mohon masukkan Materi Pokok pembelajaran terlebih dahulu.");
      return;
    }
    if (selectedProfilDimensions.length === 0) {
      setErrorMsg("Pilih minimal 1 Dimensi Profil Lulusan (maksimal 3).");
      return;
    }
    if (selectedPancaCinta.length === 0) {
      setErrorMsg("Pilih minimal 1 aspek Kurikulum Panca Cinta (maksimal 3).");
      return;
    }

    setLoading(true);
    setLoadingStep(0);
    setErrorMsg("");
    setGeneratedRPP(null);
    setIsEditing(false);

    // Simulate stepping through stages for teacher reassurance
    const timerInterval = setInterval(() => {
      setLoadingStep(prev => {
        if (prev < loadingSteps.length - 1) {
          return prev + 1;
        }
        return prev;
      });
    }, 1500);

    try {
      const response = await fetch("/api/generate-rpp", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          namaMadrasah,
          namaGuru,
          mapel,
          faseKelasSmt,
          materi,
          alokasiWaktu,
          identifikasiSiswa,
          materiCPInput,
          tujuanPembelajaranInput: rppTPInput,
          selectedProfilDimensions,
          selectedPancaCinta,
        }),
      });

      const data = await response.json();
      clearInterval(timerInterval);

      if (!response.ok) {
        throw new Error(data.error || data.details || "Gagal membuat RPP.");
      }

      setGeneratedRPP(data.rpp);
    } catch (err: any) {
      clearInterval(timerInterval);
      setErrorMsg(err.message || "Terjadi kesalahan saat menghasilkan RPP. Silakan coba kembali.");
    } finally {
      setLoading(false);
    }
  };

