Kalender Info: ${generatedProtaProsem.header.kalenderInfo}

===========================================
I. PROGRAM TAHUNAN (PROTA)
===========================================
A. SEMESTER GANJIL
`;

    generatedProtaProsem.prota.semesterGanjil.forEach(row => {
