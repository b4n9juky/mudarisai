  const generateProtaProsem = async () => {
    if (!mapel.trim()) {
      setErrorMsg("Mohon masukkan nama Mata Pelajaran terlebih dahulu.");
      return;
    }
    if (!protaCP.trim()) {
      setErrorMsg("Mohon masukkan Capaian Pembelajaran (CP) sebagai acuan.");
      return;
    }
    if (!protaTP.trim()) {
      setErrorMsg("Mohon masukkan Tujuan Pembelajaran (TP) yang ingin dicapai.");
      return;
    }
    if (!protaATP.trim()) {
      setErrorMsg("Mohon masukkan Alur Tujuan Pembelajaran (ATP) sebagai urutan logis.");
      return;
    }

    setLoadingProtaProsem(true);
    setLoadingProtaProsemStep(0);
    setErrorMsg("");
    setGeneratedProtaProsem(null);
    setIsEditingProtaProsem(false);

    // Simulate stepping through stages for teacher reassurance
    const timerInterval = setInterval(() => {
      setLoadingProtaProsemStep(prev => {
        if (prev < protaProsemLoadingSteps.length - 1) {
          return prev + 1;
        }
        return prev;
      });
    }, 1500);

    try {
      const response = await fetch("/api/generate-prota-prosem", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          mapel,
          faseKelasSmt,
          namaMadrasah,
          namaGuru,
          capaianPembelajaran: protaCP,
