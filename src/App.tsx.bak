  ];

  const generateAssessment = async () => {
    const finalMateri = assessmentMateri.trim() || materi.trim();
    if (!mapel.trim()) {
      setErrorMsg("Mohon masukkan nama Mata Pelajaran terlebih dahulu.");
      return;
    }
    if (!finalMateri) {
      setErrorMsg("Mohon masukkan Materi Pokok pembelajaran terlebih dahulu.");
      return;
    }
    if (!assessmentTP.trim()) {
      setErrorMsg("Mohon masukkan Tujuan Pembelajaran (TP) sebagai acuan luhur asesmen.");
      return;
    }

    setLoadingAssessment(true);
    setLoadingAssessmentStep(0);
    setErrorMsg("");
    setGeneratedAssessment(null);
    setIsEditingAssessment(false);

    const timerInterval = setInterval(() => {
      setLoadingAssessmentStep(prev => {
        if (prev < assessmentLoadingSteps.length - 1) {
          return prev + 1;
        }
        return prev;
      });
    }, 1500);

    try {
      const response = await fetch("/api/generate-assessment", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          namaMadrasah,
          namaGuru,
          mapel,
          faseKelasSmt,
