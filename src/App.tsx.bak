                  <div className="flex justify-between items-center text-xs mt-12 font-sans page-break-avoid">
                    <div className="flex flex-col items-center">
                      <span>Mengetahui,</span>
                      <span>Kepala Madrasah</span>
                      <div className="h-16"></div>
                      <span className="font-bold underline">_________________________</span>
                    </div>
                    <div className="flex flex-col items-center">
                      <span>Tangerang, ...................... 2026</span>
                      <span>Guru Mata Pelajaran</span>
                      <div className="h-16"></div>
                      <span className="font-bold text-center block w-32 truncate underline">{generatedProtaProsem.header.namaGuru}</span>
                    </div>
                  </div>

                </div>
              </motion.div>
            )}

            {/* INSTRUMEN ASESMEN LOADING SCREEN */}
            {activeTab === "instrumen_asesmen" && loadingAssessment && (
              <motion.div
                key="loading-box-assessment"
                initial={{ opacity: 0, scale: 0.98 }}
                animate={{ opacity: 1, scale: 1 }}
                exit={{ opacity: 0 }}
                className="bg-white rounded-2xl border border-slate-200/80 p-8 shadow-sm flex flex-col items-center justify-center min-h-[450px] text-center"
              >
                <div className="relative mb-6">
                  <div className="w-16 h-16 border-4 border-teal-100 border-t-teal-600 rounded-full animate-spin"></div>
                  <div className="absolute inset-0 flex items-center justify-center text-teal-600">
                    <ClipboardList className="w-6 h-6 animate-pulse text-teal-600" />
                  </div>
                </div>

                <h3 className="font-display font-semibold text-lg text-slate-800 mb-2">
                  Merumuskan Paket Asesmen Pembelajaran
                </h3>
                <p className="text-slate-500 text-xs max-w-sm leading-relaxed mb-6">
                  Algoritma AI sedang menyusun instrumen diagnostik prasyarat, lembar observasi sikap P2RA luhur, dan kisi-kisi butir soal sumatif berdaya nalar tinggi (HOTS).
                </p>

                {/* Loading Status Step */}
                <div className="w-full max-w-xs bg-slate-100 rounded-full h-1.5 mb-2 overflow-hidden relative">
                  <div
                    className="bg-teal-600 h-1.5 rounded-full transition-all duration-500"
                    style={{ width: `${((loadingAssessmentStep + 1) / assessmentLoadingSteps.length) * 100}%` }}
                  ></div>
                </div>
                <div className="text-[10px] uppercase font-bold text-teal-600 tracking-wider animate-pulse">
                  [Tahap {loadingAssessmentStep + 1}/{assessmentLoadingSteps.length}]: {assessmentLoadingSteps[loadingAssessmentStep]}
                </div>
              </motion.div>
            )}

            {/* INSTRUMEN ASESMEN EMPTY SCREEN */}
            {activeTab === "instrumen_asesmen" && !loadingAssessment && !generatedAssessment && (
              <motion.div
                key="empty-box-assessment"
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm flex flex-col items-center justify-center min-h-[450px] text-center"
              >
                <div className="w-12 h-12 rounded-full bg-teal-50 flex items-center justify-center mb-4">
                  <ClipboardList className="w-5 h-5 text-teal-600" />
                </div>
                <h3 className="font-display font-semibold text-slate-800 mb-1">
                  Menanti Parameter Asesmen
                </h3>
                <p className="text-xs text-slate-500 max-w-xs leading-relaxed mb-6">
                  Sempurnakan materi pokok, pilih lingkup jenis asesmen (Diagnostik, Formatif, Sumatif), lalu klik tombol formulasikan di kiri untuk menghasilkan paket instrumen asesmen otentik.
                </p>
                <div className="flex flex-wrap items-center justify-center gap-2">
                  <span className="text-[10px] px-2.5 py-1 bg-slate-100 text-slate-500 border border-slate-200/60 rounded font-medium">Auto-Prasyarat Kognitif</span>
                  <span className="text-[10px] px-2.5 py-1 bg-slate-100 text-slate-500 border border-slate-200/60 rounded font-medium">Asesmen Sikap P2RA</span>
                  <span className="text-[10px] px-2.5 py-1 bg-slate-100 text-slate-500 border border-slate-200/60 rounded font-medium">Butir Soal HOTS & Rubrik</span>
                </div>
              </motion.div>
            )}

            {/* INSTRUMEN ASESMEN OUTPUT SCREEN */}
            {activeTab === "instrumen_asesmen" && !loadingAssessment && generatedAssessment && (
              <motion.div
                key="content-box-assessment"
                initial={{ opacity: 0, y: 15 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0 }}
                className="flex flex-col gap-6"
              >
                {/* Floating toast notification */}
                {assessmentToast && (
                  <motion.div
                    initial={{ opacity: 0, y: -20 }}
                    animate={{ opacity: 1, y: 0 }}
                    exit={{ opacity: 0 }}
                    className="fixed top-6 right-6 bg-teal-800 text-white shadow-xl px-5 py-3 rounded-xl border border-teal-600/40 text-xs font-bold flex items-center gap-2.5 z-50 no-print"
                  >
                    <Check className="w-4 h-4 text-teal-300" />
                    <span>DOKUMEN ASESMEN BERHASIL DISALIN KE CLIPBOARD!</span>
                  </motion.div>
                )}

                {/* Control Action Toolbar */}
                <div className="bg-white border border-slate-200 rounded-xl p-3 shadow-sm flex flex-wrap items-center justify-between gap-3 no-print">
                  <div className="flex items-center gap-2">
                    <button
                      onClick={() => setIsEditingAssessment(!isEditingAssessment)}
                      className={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-all flex items-center gap-1.5 border ${
                        isEditingAssessment
                          ? "bg-slate-800 border-slate-900 text-white"
                          : "bg-white hover:bg-slate-50 border-slate-200 text-slate-700"
                      }`}
                    >
                      <Edit2 className="w-3.5 h-3.5" />
                      {isEditingAssessment ? "Selesai Mengedit" : "Edit Asesmen Langsung"}
                    </button>
                    {isEditingAssessment && (
                      <span className="text-[10px] text-amber-700 animate-pulse bg-amber-50 px-2 py-0.5 rounded border border-amber-200">
                        Mode Edit Aktif - Klik & Ketik di kertas dokumen
                      </span>
                    )}
                  </div>

                  <div className="flex items-center gap-1.5">
                    <button
                      onClick={handleCopyAssessmentText}
                      className="p-2 hover:bg-slate-50 text-slate-600 hover:text-slate-900 bg-white rounded-lg border border-slate-200 transition-colors"
                      title="Salin Asesmen"
                    >
                      <Copy className="w-4 h-4" />
                    </button>
                    <button
                      onClick={handleDownloadAssessmentFile}
                      className="p-2 hover:bg-slate-50 text-slate-600 hover:text-slate-900 bg-white rounded-lg border border-slate-200 transition-colors"
                      title="Unduh Teks Asesmen"
                    >
                      <Download className="w-4 h-4" />
                    </button>
                    <button
                      onClick={triggerPrint}
                      className="px-3.5 py-2 bg-slate-950 text-white hover:bg-slate-900 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5"
                      title="Cetak Dokumen"
                    >
                      <Printer className="w-4 h-4 text-teal-400" />
                      Cetak / PDF
                    </button>
                  </div>
                </div>

                {/* Classical Document Sheet (A4 format representation) */}
                <div className="bg-white border border-slate-300 shadow-xl rounded-2xl p-6 sm:p-10 font-serif text-slate-950 relative overflow-hidden print-card">
                  {/* Watermark/Emblem */}
                  <div className="absolute top-0 right-0 w-32 h-32 bg-teal-500/5 rounded-full blur-2xl pointer-events-none"></div>

                  {/* Header Lambang */}
                  <div className="flex flex-col items-center text-center border-b-2 border-slate-900 pb-5 mb-6">
                    <div className="w-12 h-12 border-2 border-emerald-600 rounded-full flex items-center justify-center p-1.5 mb-2 shrink-0">
                      <div className="w-full h-full bg-emerald-600 rounded-full flex items-center justify-center text-white font-bold text-xs">
                        MA
                      </div>
                    </div>
                    <h2 className="text-xs font-bold tracking-wider font-sans text-slate-900 uppercase">
                      KEMENTERIAN AGAMA REPUBLIK INDONESIA
                    </h2>
                    <h3 className="text-base font-black tracking-normal font-sans text-slate-900 mt-0.5 uppercase">
                      {isEditingAssessment ? (
                        <input
                          className="w-full text-center font-bold p-0 text-base bg-transparent border-b border-dashed border-teal-300 focus:outline-none"
                          value={generatedAssessment.header.namaMadrasah}
                          onChange={(e) => {
                            setGeneratedAssessment({
                              ...generatedAssessment,
                              header: { ...generatedAssessment.header, namaMadrasah: e.target.value }
                            });
                          }}
                        />
                      ) : (
                        generatedAssessment.header.namaMadrasah
                      )}
                    </h3>
                    <p className="text-[9px] text-slate-500 font-sans tracking-wide mt-1 italic uppercase">
                      PAKET INSTRUMEN EVALUASI & ASESMEN MATERI PEMBELAJARAN
                    </p>
                  </div>

                  {/* Metadata Table */}
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-sans text-slate-800 mb-8 p-4 bg-slate-50 border border-slate-200/80 rounded-xl">
                    <div className="flex flex-col gap-1">
                      <div><span className="font-semibold text-slate-400">Mata Pelajaran:</span> {generatedAssessment.header.mapel}</div>
                      <div><span className="font-semibold text-slate-400">Materi Pokok:</span> {generatedAssessment.header.materi}</div>
                      <div>
                        <span className="font-semibold text-slate-400">Tujuan Pembelajaran:</span>{" "}
                        {isEditingAssessment ? (
                          <textarea
                            rows={2}
                            className="w-full px-1 p-0.5 text-xs bg-white border border-teal-200 rounded focus:outline-none focus:ring-1 focus:ring-teal-500"
                            value={generatedAssessment.header.tujuanPembelajaran}
                            onChange={(e) => {
                              setGeneratedAssessment({
                                ...generatedAssessment,
                                header: { ...generatedAssessment.header, tujuanPembelajaran: e.target.value }
                              });
                            }}
                          />
                        ) : (
                          generatedAssessment.header.tujuanPembelajaran
                        )}
                      </div>
                    </div>
                    <div className="flex flex-col gap-1 md:border-l md:border-slate-200 md:pl-4">
                      <div><span className="font-semibold text-slate-400">Kelas & Semester:</span> {generatedAssessment.header.faseKelasSmt}</div>
                      <div><span className="font-semibold text-slate-400">Alokasi Waktu:</span> {generatedAssessment.header.alokasiWaktu}</div>
                      <div><span className="font-semibold text-slate-400">Guru Pengampu:</span> {generatedAssessment.header.namaGuru}</div>
                    </div>
                  </div>

                  {/* Section 1: Diagnostik */}
                  {generatedAssessment.asesmenDiagnostik && (
                    <div className="mb-8">
                      <div className="flex items-center gap-2 mb-3 border-b border-teal-200 pb-1.5 no-print">
                        <span className="w-2.5 h-2.5 bg-teal-600 rounded-full shrink-0"></span>
                        <h4 className="font-sans font-bold text-slate-900 text-sm tracking-wide uppercase">
                          I. Asesmen Diagnostik (Awal Pembelajaran)
                        </h4>
                      </div>
                      <h4 className="print-only hidden font-sans font-bold text-slate-900 text-sm uppercase mb-3">
                        I. ASESMEN DIAGNOSTIK (AWAL PEMBELAJARAN)
                      </h4>

                      {/* Diagnostic Kognitif */}
                      <div className="mb-6">
                        <div className="text-xs bg-teal-50 text-teal-800 rounded p-3 mb-3 border border-teal-100 font-sans flex flex-col gap-0.5">
                          <span className="font-bold uppercase tracking-wider text-[10px]">Tujuan Diagnostik Kognitif (Prasyarat):</span>
                          <span>{generatedAssessment.asesmenDiagnostik.kognitif.tujuan}</span>
                        </div>

                        <div className="overflow-x-auto">
                          <table className="w-full text-xs font-sans text-slate-800 border-collapse border border-slate-200">
                            <thead>
                              <tr className="bg-slate-150 text-slate-700">
                                <th className="border border-slate-200 p-2 text-center w-12">No</th>
                                <th className="border border-slate-200 p-2 text-left">Pertanyaan Prasyarat Materi</th>
                                <th className="border border-slate-200 p-2 text-left w-64">Rekomendasi Tindak Lanjut Guru</th>
                              </tr>
                            </thead>
                            <tbody>
                              {generatedAssessment.asesmenDiagnostik.kognitif.pertanyaan.map((q, idx) => (
                                <tr key={idx} className="hover:bg-slate-50/50 transition-colors">
                                  <td className="border border-slate-200 p-2 text-center font-bold">{q.no || (idx + 1)}</td>
                                  <td className="border border-slate-200 p-2 text-slate-900">
                                    {isEditingAssessment ? (
                                      <input
                                        className="w-full p-1 border border-teal-200 rounded focus:outline-none focus:bg-teal-50/10 text-xs font-sans"
                                        value={q.soal}
                                        onChange={(e) => {
                                          const updated = [...generatedAssessment.asesmenDiagnostik.kognitif.pertanyaan];
                                          updated[idx].soal = e.target.value;
                                          setGeneratedAssessment({
                                            ...generatedAssessment,
                                            asesmenDiagnostik: {
                                              ...generatedAssessment.asesmenDiagnostik,
                                              kognitif: {
                                                ...generatedAssessment.asesmenDiagnostik.kognitif,
                                                pertanyaan: updated,
                                              }
                                            }
                                          });
                                        }}
                                      />
                                    ) : (
                                      q.soal
                                    )}
                                  </td>
                                  <td className="border border-slate-200 p-2 text-slate-600 bg-slate-50/30">
                                    {isEditingAssessment ? (
                                      <textarea
                                        rows={2}
                                        className="w-full p-1 border border-teal-200 rounded focus:outline-none focus:bg-teal-50/10 text-[11px] font-sans"
                                        value={q.tindakLanjut}
                                        onChange={(e) => {
                                          const updated = [...generatedAssessment.asesmenDiagnostik.kognitif.pertanyaan];
                                          updated[idx].tindakLanjut = e.target.value;
                                          setGeneratedAssessment({
                                            ...generatedAssessment,
                                            asesmenDiagnostik: {
                                              ...generatedAssessment.asesmenDiagnostik,
                                              kognitif: {
                                                ...generatedAssessment.asesmenDiagnostik.kognitif,
                                                pertanyaan: updated,
                                              }
                                            }
                                          });
                                        }}
                                      />
                                    ) : (
                                      q.tindakLanjut
                                    )}
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </div>

                      {/* Diagnostic Non-Kognitif */}
                      <div>
                        <div className="text-xs bg-slate-50 text-slate-700 rounded p-3 mb-3 border border-slate-200/85 font-sans flex flex-col gap-0.5">
                          <span className="font-bold uppercase tracking-wider text-[10px] text-slate-500">Tujuan Asesmen Non-Kognitif:</span>
                          <span>{generatedAssessment.asesmenDiagnostik.nonKognitif.tujuan}</span>
                        </div>

                        <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                          {generatedAssessment.asesmenDiagnostik.nonKognitif.aspek.map((a, idx) => (
                            <div key={idx} className="p-3 bg-teal-50/10 border border-slate-200 rounded-lg text-xs font-sans flex flex-col justify-between hover:border-teal-300 transition-all">
                              <div>
                                <span className="font-bold text-teal-700 block text-[10px] uppercase tracking-normal mb-1">
                                  Aspek {idx + 1}: {a.indikator}
                                </span>
                                <p className="text-slate-800 leading-relaxed italic">
                                  "{isEditingAssessment ? (
                                    <textarea
                                      rows={3}
                                      className="w-full p-1 border border-teal-200 rounded text-xs bg-white resize-none focus:outline-none"
                                      value={a.pertanyaan}
                                      onChange={(e) => {
                                        const updated = [...generatedAssessment.asesmenDiagnostik.nonKognitif.aspek];
                                        updated[idx].pertanyaan = e.target.value;
                                        setGeneratedAssessment({
                                          ...generatedAssessment,
                                          asesmenDiagnostik: {
                                            ...generatedAssessment.asesmenDiagnostik,
                                            nonKognitif: {
                                              ...generatedAssessment.asesmenDiagnostik.nonKognitif,
                                              aspek: updated
                                            }
                                          }
                                        });
                                      }}
                                    />
                                  ) : (
                                    a.pertanyaan
                                  )}"
                                </p>
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>
                  )}

                  {/* Section 2: Formatif */}
                  {generatedAssessment.asesmenFormatif && (
                    <div className="mb-8 page-break-before">
                      <div className="flex items-center gap-2 mb-3 border-b border-teal-200 pb-1.5 no-print">
                        <span className="w-2.5 h-2.5 bg-teal-600 rounded-full shrink-0"></span>
                        <h4 className="font-sans font-bold text-slate-900 text-sm tracking-wide uppercase">
                          II. Asesmen Formatif (Proses Pembelajaran)
                        </h4>
                      </div>
                      <h4 className="print-only hidden font-sans font-bold text-slate-900 text-sm uppercase mb-3">
                        II. ASESMEN FORMATIF (DALAM PROSES BELAJAR)
                      </h4>

                      {/* Observasi Sikap */}
                      <div className="mb-6">
                        <div className="mb-2 text-xs font-sans">
                          <span className="font-extrabold text-slate-850 block mb-1">A. Lembar Kerja Observasi Sikap P2RA &amp; Nilai Luhur</span>
                          <p className="text-slate-600 leading-relaxed italic bg-slate-50 p-2.5 rounded border border-slate-200">
                            <span className="font-bold not-italic font-sans text-xs text-slate-600 bg-white shadow-sm border border-slate-200 px-1.5 py-0.5 rounded mr-1.5 inline-block">Panduan Guru</span>
                            {generatedAssessment.asesmenFormatif.observasiSikap.instruksi}
                          </p>
                        </div>

                        <div className="mb-3 text-xs font-sans">
                          <span className="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Kriteria Karakter Dinilai:</span>
                          <div className="flex flex-wrap gap-1.5 mt-1">
                            {generatedAssessment.asesmenFormatif.observasiSikap.kriteria.map((krit, idx) => (
                              <span key={idx} className="px-2.5 py-1 bg-emerald-50 text-emerald-805 border border-emerald-200/50 rounded-full font-bold">
                                {krit}
                              </span>
                            ))}
                          </div>
                        </div>

                        <div className="overflow-x-auto">
                          <table className="w-full text-xs font-sans text-slate-800 border-collapse border border-slate-200">
                            <thead>
                              <tr className="bg-slate-100 text-slate-700">
                                <th className="border border-slate-200 p-2 text-center">Skor 4 (Sangat Baik)</th>
                                <th className="border border-slate-200 p-2 text-center">Skor 3 (Baik)</th>
                                <th className="border border-slate-200 p-2 text-center">Skor 2 (Cukup)</th>
                                <th className="border border-slate-200 p-2 text-center">Skor 1 (Perlu Bimbingan)</th>
                              </tr>
                            </thead>
                            <tbody>
                              {generatedAssessment.asesmenFormatif.observasiSikap.rubrik.map((rub, idx) => (
                                <tr key={idx}>
                                  <td className="border border-slate-200 p-2 text-[11px] align-top leading-relaxed">
                                    {rub.skor4}
                                  </td>
                                  <td className="border border-slate-200 p-2 text-[11px] align-top bg-slate-50/50 leading-relaxed animate-fade-in">
                                    {rub.skor3}
                                  </td>
                                  <td className="border border-slate-200 p-2 text-[11px] align-top leading-relaxed">
                                    {rub.skor2}
                                  </td>
                                  <td className="border border-slate-200 p-2 text-[11px] align-top bg-rose-50/10 leading-relaxed">
                                    {rub.skor1}
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </div>

                      {/* Penilaian Diri */}
                      <div>
                        <div className="mb-2 text-xs font-sans">
                          <span className="font-extrabold text-slate-800 block mb-1">B. Lembar Penilaian Diri (Siswa Mandiri)</span>
                          <p className="text-slate-650 leading-relaxed italic bg-teal-50/20 p-2.5 rounded border border-teal-100">
                            <span className="font-bold not-italic font-sans text-xs text-teal-800 bg-white shadow-sm border border-teal-200 px-1.5 py-0.5 rounded mr-1.5 inline-block">Panduan Siswa</span>
                            {generatedAssessment.asesmenFormatif.penilaianDiri.instruksi}
                          </p>
                        </div>

                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div className="bg-slate-50 border border-slate-200 rounded-xl p-4 font-sans text-xs">
                            <span className="font-bold text-slate-700 block mb-2.5">Pernyataan Refleksi Diri:</span>
                            <div className="flex flex-col gap-2.5">
                              {generatedAssessment.asesmenFormatif.penilaianDiri.pernyataan.map((str, idx) => (
                                <div key={idx} className="flex gap-2 items-start">
                                  <span className="font-extrabold text-teal-700">{idx + 1}.</span>
                                  <p className="flex-1 text-slate-800 leading-relaxed">
                                    {isEditingAssessment ? (
                                      <input
                                        className="w-full p-0.5 border border-teal-100 rounded text-xs bg-white focus:outline-none"
                                        value={str}
                                        onChange={(e) => {
                                          const updated = [...generatedAssessment.asesmenFormatif.penilaianDiri.pernyataan];
                                          updated[idx] = e.target.value;
                                          setGeneratedAssessment({
                                            ...generatedAssessment,
                                            asesmenFormatif: {
                                              ...generatedAssessment.asesmenFormatif,
                                              penilaianDiri: {
                                                ...generatedAssessment.asesmenFormatif.penilaianDiri,
                                                pernyataan: updated
                                              }
                                            }
                                          });
                                        }}
                                      />
                                    ) : (
                                      str
                                    )}
                                  </p>
                                </div>
                              ))}
                            </div>
                          </div>

                          <div className="bg-white border border-slate-200 rounded-xl p-4 font-sans text-xs flex flex-col justify-center">
                            <span className="font-bold text-slate-700 block mb-1.5">Skala Penilaian Sejujurnya:</span>
                            <ul className="list-disc pl-4 text-slate-500 space-y-1">
                              <li><strong>Ya / Setuju:</strong> Jika merasa selalu berupaya nyata melakukannya.</li>
                              <li><strong>Ragu-Ragu:</strong> Jika terkadang melaksanakan namun masih butuh pengingat.</li>
                              <li><strong>Tidak / Belum:</strong> Belum berbuat nyata, butuh pembiasaan diri ekstra.</li>
                            </ul>
                          </div>
                        </div>

                      </div>
                    </div>
                  )}

                  {/* Section 3: Sumatif */}
                  {generatedAssessment.asesmenSumatif && (
                    <div className="mb-8 page-break-before">
                      <div className="flex items-center gap-2 mb-3 border-b border-teal-200 pb-1.5 no-print">
                        <span className="w-2.5 h-2.5 bg-teal-600 rounded-full shrink-0"></span>
                        <h4 className="font-sans font-bold text-slate-900 text-sm tracking-wide uppercase">
                          III. Asesmen Sumatif (Evaluasi Capaian Akhir)
                        </h4>
                      </div>
                      <h4 className="print-only hidden font-sans font-bold text-slate-900 text-sm uppercase mb-3">
                        III. ASESMEN SUMATIF (EVALUASI CAPAIAN AKHIR)
                      </h4>

                      <div className="text-xs bg-slate-50 text-slate-700 rounded p-3 mb-5 border border-slate-200 font-sans">
                        <span className="font-bold uppercase tracking-wider text-[10px] text-teal-700 block mb-0.5">Analisis Ringkas Kisi-Kisi Soal:</span>
                        <p className="leading-relaxed">{generatedAssessment.asesmenSumatif.kisiKisi}</p>
                      </div>

                      {/* Multi-Format Questions (PG & Esai) */}
                      <div className="mb-6">
                        <span className="font-extrabold font-sans text-xs block text-slate-900 mb-3 uppercase tracking-wide">A. Lembar Ujian Butir Soal Tertulis:</span>

                        <div className="flex flex-col gap-5">
                          {generatedAssessment.asesmenSumatif.soalPgDanEsai.map((item, idx) => (
                            <div key={idx} className="bg-slate-50/30 border border-slate-200 rounded-xl p-4 text-xs font-sans flex flex-col gap-2.5 hover:border-slate-300 transition-colors">
                              <div className="flex items-center justify-between">
                                <span className="font-extrabold text-[10px] text-teal-800 bg-teal-50 px-2 py-0.5 border border-teal-200 rounded-full uppercase">
                                  Soal {item.no || (idx + 1)} • {item.tipe}
                                </span>
                                <span className="text-[10px] font-bold text-slate-400">
                                  Ranah: {item.tingkatKognitif}
                                </span>
                              </div>

                              <p className="text-sm font-semibold text-slate-900 leading-relaxed font-serif">
                                {isEditingAssessment ? (
                                  <textarea
                                    rows={2}
                                    className="w-full p-1 border border-teal-200 rounded focus:outline-none"
                                    value={item.pertanyaan}
                                    onChange={(e) => {
                                      const updated = [...generatedAssessment.asesmenSumatif.soalPgDanEsai];
                                      updated[idx].pertanyaan = e.target.value;
                                      setGeneratedAssessment({
                                        ...generatedAssessment,
                                        asesmenSumatif: {
                                          ...generatedAssessment.asesmenSumatif,
                                          soalPgDanEsai: updated
                                        }
                                      });
                                    }}
                                  />
                                ) : (
                                  item.pertanyaan
                                )}
                              </p>

                              {item.opsi && item.opsi.length > 0 && (
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-2 mt-1">
                                  {item.opsi.map((o, oIdx) => (
                                    <div
                                      key={oIdx}
                                      className={`p-2 rounded-lg border font-medium bg-white text-xs ${
                                        o.startsWith(item.kunciJawaban)
                                          ? "border-emerald-400 bg-emerald-50/20 text-emerald-900"
                                          : "border-slate-200 text-slate-700"
                                      }`}
                                    >
                                      {o}
                                    </div>
                                  ))}
                                </div>
                              )}

                              <div className="mt-2 text-[11px] bg-white border border-slate-200 rounded-lg p-2.5 flex flex-col gap-1 text-slate-600 leading-relaxed shadow-sm">
                                <div><span className="font-extrabold text-teal-700 uppercase tracking-widest text-[9px] mr-1">Kunci Jawaban:</span> <strong>{item.kunciJawaban}</strong></div>
                                <div><span className="font-bold text-slate-400 uppercase tracking-wide text-[9px] mr-1 font-sans">Penjelasan Analitis:</span> {item.penjelasan}</div>
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>

                      {/* Rubrik Penilaian Sumatif */}
                      <div>
                        <span className="font-extrabold font-sans text-xs block text-slate-900 mb-3 uppercase tracking-wide">B. Rubrik Penilaian &amp; Skoring Capaian Akhir:</span>

                        <div className="overflow-x-auto">
                          <table className="w-full text-xs font-sans text-slate-800 border-collapse border border-slate-200">
                            <thead>
                              <tr className="bg-slate-100 text-slate-700 font-bold">
                                <th className="border border-slate-200 p-2 text-left w-48">Kriteria Asesmen</th>
                                <th className="border border-slate-200 p-2 text-left">Deskripsi Pencapaian (Skor 4 s.d 1)</th>
                              </tr>
                            </thead>
                            <tbody>
                              {generatedAssessment.asesmenSumatif.rubrikPenilaianSumatif.map((rub, idx) => (
                                <tr key={idx}>
                                  <td className="border border-slate-200 p-2 font-bold text-slate-900 align-top bg-slate-50/30">
                                    {rub.kriteria}
                                  </td>
                                  <td className="border border-slate-200 p-2 align-top">
                                    <div className="grid grid-cols-1 md:grid-cols-4 gap-2 text-[10px]">
                                      {rub.deskripsiSkor.map((desc, dIdx) => (
                                        <div key={dIdx} className="p-1.5 rounded bg-slate-50 border border-slate-200">
                                          {desc}
                                        </div>
                                      ))}
                                    </div>
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </div>

                    </div>
                  )}

                  {/* SIGNATURES */}
                  <div className="flex justify-between items-center text-xs mt-12 font-sans page-break-avoid border-t-0 pt-0">
                    <div className="flex flex-col items-center">
                      <span>Mengetahui,</span>
                      <span>Kepala Madrasah</span>
                      <div className="h-16"></div>
                      <span className="font-bold underline">_________________________</span>
                    </div>
                    <div className="flex flex-col items-center">
                      <span>Tangerang, ...................... 2026</span>
                      <span>Guru Mata Pelajaran</span>
                      <div className="h-16"></div>
                      <span className="font-bold text-center block w-32 truncate underline">{generatedAssessment.header.namaGuru}</span>
                    </div>
                  </div>

                </div>
              </motion.div>
            )}

          </AnimatePresence>

        </div>

      </main>

      {/* Footer Branding Area */}
      <footer className="bg-emerald-950 text-emerald-300 py-6 px-4 border-t border-emerald-900 mt-12 text-center text-xs no-print">
        <p className="font-medium tracking-wide">
          Pembuat RPP Digital © 2026 • Dirancang untuk Penguatan Karakter Kurikulum Merdeka & Pendidikan Berbasis Cinta
        </p>
        <p className="text-[10px] text-emerald-500 font-light mt-1 max-w-xl mx-auto">
          Teknologi asisten pengajar yang berkesadaran sosial, kognitif, ekologis dan spiritual demi mencerdaskan kehidupan bangsa secara berkarakter luhur.
        </p>
      </footer>
    </div>
  );
}
