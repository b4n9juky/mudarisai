                      II. PROGRAM SEMESTER (PROSEM) - GANJIL (JULI - DESEMBER)
                    </h3>

                    <div className="overflow-x-auto select-none max-w-full">
                      <table className="w-full text-[9px] border border-slate-300 border-collapse table-fixed min-w-[700px] print:min-w-0">
                        <thead>
                          <tr className="bg-slate-50 text-slate-700">
                            <th className="border border-slate-300 p-1 text-center w-8" rowSpan={2}>No</th>
                            <th className="border border-slate-300 p-1 w-44 text-left" rowSpan={2}>Materi Pokok / Bab</th>
                            <th className="border border-slate-300 p-1 text-center w-12" rowSpan={2}>JP</th>
                            {generatedProtaProsem.prosemGanjil.bulan.map((bln, bIdx) => (
                              <th key={bIdx} className="border border-slate-300 p-0.5 text-center truncate text-[10px] font-bold" colSpan={4}>
                                {bln}
                              </th>
                            ))}
                          </tr>
                          <tr className="bg-slate-100 text-slate-500 text-[8px]">
                            {Array.from({ length: 24 }).map((_, wIdx) => (
                              <th key={wIdx} className="border border-slate-300 p-0.5 text-center font-normal">
                                M{(wIdx % 4) + 1}
                              </th>
                            ))}
                          </tr>
                        </thead>
                        <tbody>
                          {generatedProtaProsem.prosemGanjil.materiRows.map((row, rIdx) => (
                            <tr key={rIdx} className="hover:bg-slate-50/50">
                              <td className="border border-slate-300 p-1 text-center font-bold font-mono">{row.no || String(rIdx + 1)}</td>
                              <td className="border border-slate-300 p-1 font-semibold text-slate-800 truncate" title={row.babMateri}>
                                {row.babMateri}
                              </td>
                              <td className="border border-slate-300 p-1 text-center font-bold text-slate-700">{row.alokasiWaktu}</td>
                              {row.mingguMaping.map((mapVal, mIdx) => (
                                <td
                                  key={mIdx}
                                  className={`border border-slate-300 p-0.5 text-center font-bold transition-all ${
                                    mapVal ? "bg-emerald-100 text-emerald-950 font-mono" : "bg-white text-slate-300"
                                  }`}
                                >
                                  {isEditingProtaProsem ? (
                                    <input
                                      className="w-full text-center font-bold p-0 text-[10px] bg-transparent focus:outline-none focus:bg-emerald-50 text-emerald-900"
                                      value={mapVal}
                                      onChange={(e) => {
                                        const rows = [...generatedProtaProsem.prosemGanjil.materiRows];
                                        rows[rIdx].mingguMaping[mIdx] = e.target.value;
                                        setGeneratedProtaProsem({
                                          ...generatedProtaProsem,
                                          prosemGanjil: { ...generatedProtaProsem.prosemGanjil, materiRows: rows }
                                        });
                                      }}
                                    />
                                  ) : (
                                    mapVal || ""
                                  )}
                                </td>
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </div>

                  {/* 3. PROGRAM SEMESTER (PROSEM) GENAP */}
                  <div className="page-break-before-always flex flex-col gap-3">
                    <h3 className="text-xs uppercase font-extrabold tracking-wider text-slate-800 bg-slate-100 px-2.5 py-1.5 border-l-4 border-emerald-600 font-sans">
                      III. PROGRAM SEMESTER (PROSEM) - GENAP (JANUARI - JUNI)
                    </h3>

                    <div className="overflow-x-auto select-none max-w-full">
                      <table className="w-full text-[9px] border border-slate-300 border-collapse table-fixed min-w-[700px] print:min-w-0">
                        <thead>
                          <tr className="bg-slate-50 text-slate-700">
                            <th className="border border-slate-300 p-1 text-center w-8" rowSpan={2}>No</th>
                            <th className="border border-slate-300 p-1 w-44 text-left" rowSpan={2}>Materi Pokok / Bab</th>
                            <th className="border border-slate-300 p-1 text-center w-12" rowSpan={2}>JP</th>
                            {generatedProtaProsem.prosemGenap.bulan.map((bln, bIdx) => (
                              <th key={bIdx} className="border border-slate-300 p-0.5 text-center truncate text-[10px] font-bold" colSpan={4}>
                                {bln}
                              </th>
                            ))}
                          </tr>
                          <tr className="bg-slate-100 text-slate-500 text-[8px]">
                            {Array.from({ length: 24 }).map((_, wIdx) => (
                              <th key={wIdx} className="border border-slate-300 p-0.5 text-center font-normal">
                                M{(wIdx % 4) + 1}
                              </th>
                            ))}
                          </tr>
                        </thead>
                        <tbody>
                          {generatedProtaProsem.prosemGenap.materiRows.map((row, rIdx) => (
                            <tr key={rIdx} className="hover:bg-slate-50/50">
                              <td className="border border-slate-300 p-1 text-center font-bold font-mono">{row.no || String(rIdx + 1)}</td>
                              <td className="border border-slate-300 p-1 font-semibold text-slate-800 truncate" title={row.babMateri}>
                                {row.babMateri}
                              </td>
                              <td className="border border-slate-300 p-1 text-center font-bold text-slate-700">{row.alokasiWaktu}</td>
                              {row.mingguMaping.map((mapVal, mIdx) => (
                                <td
                                  key={mIdx}
                                  className={`border border-slate-300 p-0.5 text-center font-bold transition-all ${
                                    mapVal ? "bg-emerald-100 text-emerald-950 font-mono" : "bg-white text-slate-300"
                                  }`}
                                >
                                  {isEditingProtaProsem ? (
                                    <input
                                      className="w-full text-center font-bold p-0 text-[10px] bg-transparent focus:outline-none focus:bg-emerald-50 text-emerald-900"
                                      value={mapVal}
                                      onChange={(e) => {
                                        const rows = [...generatedProtaProsem.prosemGenap.materiRows];
                                        rows[rIdx].mingguMaping[mIdx] = e.target.value;
                                        setGeneratedProtaProsem({
                                          ...generatedProtaProsem,
                                          prosemGenap: { ...generatedProtaProsem.prosemGenap, materiRows: rows }
                                        });
                                      }}
                                    />
                                  ) : (
                                    mapVal || ""
                                  )}
                                </td>
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
