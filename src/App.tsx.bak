// Types for RPP Model Form & Generated Output
interface RPPHeader {
  namaMadrasah: string;
  namaGuru: string;
  mapel: string;
  faseKelasSmt: string;
  materi: string;
  alokasiWaktu: string;
}

interface RPPIdentifikasi {
  pesertaDidikDetail: string;
  materiPelajaranCP: string;
  dimensiProfil: string[];
  kurikulumPancaCinta: string[];
}

interface RPPDesainPembelajaran {
  capaianPembelajaran: string;
  lintasDisiplinIlmu: string;
  tujuanPembelajaran: string[];
  topikPembelajaran: string;
  praktikPedagogis: string;
  kemitraanPembelajaran: string;
  lingkunganPembelajaran: string;
  pemanfaatanDigital: string;
}

interface RPPLangkahPembelajaran {
  memahami: string[];
  mengaplikasi: string[];
  merefleksi: string[];
}

interface RPPAsesmen {
  awal: string;
  proses: string;
  akhir: string;
}

interface RubiKriteria {
  aspek: string;
  kriteriaSangatBaik: string;
  kriteriaBaik: string;
  kriteriaCukup: string;
  kriteriaPerluBimbingan: string;
}

interface RPPPengalamanBelajar {
  prinsipPembelajaran: string;
  langkahPembelajaran: RPPLangkahPembelajaran;
  asesmenPembelajaran: RPPAsesmen;
  rubrikPenilaian: RubiKriteria[];
  refleksiSiswa: string[];
  refleksiGuru: string[];
}

interface RPPData {
  header: RPPHeader;
  identifikasi: RPPIdentifikasi;
  desainPembelajaran: RPPDesainPembelajaran;
  pengalamanBelajar: RPPPengalamanBelajar;
}

// LKPD interfaces
interface LKPDHeader {
  namaMadrasah: string;
  namaGuru: string;
  mapel: string;
  faseKelasSmt: string;
  materi: string;
  alokasiWaktu: string;
  tujuanPembelajaran: string;
}

interface LKPDStimulus {
  judul: string;
  narasi: string;
}

interface LKPDAktivitas {
  jenis: string;
  namaAktivitas: string;
  panduanLangkah: string[];
}

interface LKPDSoal {
  level: string;
  pertanyaan: string;
  petunjukJawaban: string;
}

interface LKPDRefleksi {
  instruksi: string;
  pertanyaan: string[];
}

interface LKPDRubrik {
  kriteria: string;
  skor4: string;
  skor3: string;
  skor2: string;
  skor1: string;
}

interface LKPDData {
  header: LKPDHeader;
  petunjukKerja: string[];
  stimulusKontekstual: LKPDStimulus;
  aktivitas: LKPDAktivitas;
  pertanyaanC1C6: LKPDSoal[];
  kesimpulan: string;
  refleksi: LKPDRefleksi;
  rubrikPenilaian: LKPDRubrik[];
}

// PROTA & PROSEM interfaces
interface ProtaHeader {
  namaMadrasah: string;
  namaGuru: string;
  mapel: string;
  faseKelasSmt: string;
  kalenderInfo: string;
}

interface ProtaRow {
  no: string;
  babMateri: string;
  tujuanDanAlurPembelajaran: string;
  alokasiWaktu: string;
}

interface ProtaSection {
  semesterGanjil: ProtaRow[];
  semesterGenap: ProtaRow[];
  totalAlokasiWaktu: string;
}

interface ProsemRow {
  no: string;
  babMateri: string;
  alokasiWaktu: string;
  mingguMaping: string[];
}

interface ProsemSection {
  bulan: string[];
  materiRows: ProsemRow[];
}

interface ProtaProsemData {
  header: ProtaHeader;
  prota: ProtaSection;
  prosemGanjil: ProsemSection;
  prosemGenap: ProsemSection;
  analisisMingguEfektif: {
    totalMingguEfektifGanjil: string;
    totalMingguEfektifGenap: string;
    keteranganEfektifitas: string;
  };
}

// INTRUMEN ASESMEN interfaces
interface AssessmentQuestion {
  no: string;
  tipe: string;
  tingkatKognitif: string;
  pertanyaan: string;
  opsi?: string[];
  kunciJawaban: string;
  penjelasan: string;
}

interface DiagnosticKognitif {
  tujuan: string;
  pertanyaan: {
    no: string;
    soal: string;
    tindakLanjut: string;
  }[];
}

interface DiagnosticNonKognitif {
  tujuan: string;
  aspek: {
    pertanyaan: string;
    indikator: string;
  }[];
}

interface AssessmentDiagnostic {
  kognitif: DiagnosticKognitif;
  nonKognitif: DiagnosticNonKognitif;
}

interface FormativeObservasiSikap {
  instruksi: string;
  kriteria: string[];
  rubrik: {
    skor4: string;
    skor3: string;
    skor2: string;
    skor1: string;
  }[];
}

interface AssessmentFormative {
  observasiSikap: FormativeObservasiSikap;
  penilaianDiri: {
    instruksi: string;
    pernyataan: string[];
  };
}

interface AssessmentSummative {
  kisiKisi: string;
  soalPgDanEsai: AssessmentQuestion[];
  rubrikPenilaianSumatif: {
    kriteria: string;
    deskripsiSkor: string[];
  }[];
}

interface AssessmentData {
  header: {
    namaMadrasah: string;
    namaGuru: string;
    mapel: string;
    faseKelasSmt: string;
    materi: string;
    alokasiWaktu: string;
    tujuanPembelajaran: string;
  };
  asesmenDiagnostik: AssessmentDiagnostic;
  asesmenFormatif: AssessmentFormative;
  asesmenSumatif: AssessmentSummative;
}

