          alurTujuanPembelajaran: protaATP,
          fileName: uploadedCalendarFile?.name || "",
          fileSize: uploadedCalendarFile?.size || 0,
        })
      });

      clearInterval(timerInterval);

      if (!response.ok) {
        const errData = await response.json().catch(() => ({}));
        throw new Error(errData.error || `Error status ${response.status}`);
      }

      const resData = await response.json();
      if (!resData || !resData.protaProsem) {
        throw new Error("Format respon Kurikulum PROTA-PROSEM tidak didukung.");
      }

      setGeneratedProtaProsem(resData.protaProsem);
    } catch (err: any) {
      setErrorMsg(err.message || String(err));
    } finally {
      setLoadingProtaProsem(false);
      clearInterval(timerInterval);
    }
  };

  const handleCopyProtaProsemText = () => {
    if (!generatedProtaProsem) return;
    
    let text = `PROGRAM TAHUNAN (PROTA) & PROGRAM SEMESTER (PROSEM)
Madrasah: ${generatedProtaProsem.header.namaMadrasah}
Guru: ${generatedProtaProsem.header.namaGuru}
Mapel: ${generatedProtaProsem.header.mapel}
