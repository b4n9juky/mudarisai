      setErrorMsg("Mohon masukkan nama Mata Pelajaran (Mapel) terlebih dahulu.");
      return;
    }
    if (!finalMateri) {
      setErrorMsg("Mohon masukkan Materi Pokok pembelajaran terlebih dahulu.");
      return;
    }
    if (!lkpdTP.trim()) {
      setErrorMsg("Mohon masukkan Tujuan Pembelajaran (TP) sebagai acuan luhur LKPD.");
