# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AI_MODEL: Optional. Override the default model used across all features.
# Uses OpenRouter model slugs. Default is "openai/gpt-4o-mini".
# Examples: "google/gemini-2.0-flash-001", "anthropic/claude-3.5-sonnet",
#           "meta-llama/llama-3.2-90b-vision-instruct", "openai/gpt-4o"
# AI_MODEL="openai/gpt-4o-mini"
